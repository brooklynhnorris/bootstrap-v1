<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logiri — Double D Trailers</title>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
    <style>
        :root {
            --bg-primary: #ffffff;
            --bg-secondary: #f8f8fa;
            --bg-tertiary: #f0f0f3;
            --bg-card: #ffffff;
            --border-subtle: #e4e4e8;
            --border-medium: #d0d0d6;
            --border-accent: #b0b0ba;
            --text-primary: #1a1a1f;
            --text-secondary: #5c5c66;
            --text-muted: #9898a0;
            --accent-blue: #2563eb;
            --accent-blue-dim: #eff4ff;
            --accent-blue-border: #bfdbfe;
            --accent-red: #dc2626;
            --accent-red-dim: #fef2f2;
            --accent-red-border: #fecaca;
            --accent-yellow: #d97706;
            --accent-yellow-dim: #fffbeb;
            --accent-yellow-border: #fde68a;
            --accent-green: #16a34a;
            --accent-green-dim: #f0fdf4;
            --accent-green-border: #bbf7d0;
            --accent-purple: #7c3aed;
            --accent-purple-dim: #f5f3ff;
            --shadow-sm: 0 1px 2px rgba(0,0,0,0.04);
            --shadow-md: 0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.03);
            --radius-sm: 6px;
            --radius-md: 10px;
            --radius-lg: 14px;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif; background: var(--bg-secondary); color: var(--text-primary); height: 100vh; display: flex; overflow: hidden; }

        /* Left Sidebar */
        #sidebar { width: 240px; min-width: 240px; background: var(--bg-primary); border-right: 1px solid var(--border-subtle); display: flex; flex-direction: column; overflow: hidden; }
        #sidebar-header { padding: 16px 18px; border-bottom: 1px solid var(--border-subtle); }
        #sidebar-header h1 { font-size: 18px; font-weight: 700; color: var(--text-primary); letter-spacing: -0.3px; }
        #sidebar-header p { font-size: 10px; color: var(--text-muted); margin-top: 2px; text-transform: uppercase; letter-spacing: 0.8px; }
        .user-card { padding: 12px 18px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; gap: 9px; }
        .user-avatar { width: 30px; height: 30px; border-radius: 50%; background: var(--accent-blue-dim); color: var(--accent-blue); display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 600; border: 1px solid var(--accent-blue-border); flex-shrink: 0; }
        .user-info { flex: 1; min-width: 0; }
        .user-name { font-size: 12px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .user-role { font-size: 10px; color: var(--text-muted); }
        .user-logout { font-size: 10px; color: var(--text-muted); text-decoration: none; padding: 3px 7px; border-radius: 4px; transition: all 0.15s; flex-shrink: 0; }
        .user-logout:hover { background: var(--bg-tertiary); color: var(--text-secondary); }
        .sidebar-tabs { display: flex; border-bottom: 1px solid var(--border-subtle); }
        .sidebar-tab { flex: 1; padding: 9px 0; text-align: center; font-size: 11px; font-weight: 500; color: var(--text-muted); cursor: pointer; border-bottom: 2px solid transparent; transition: all 0.15s; }
        .sidebar-tab.active { color: var(--accent-blue); border-bottom-color: var(--accent-blue); }
        #sidebar-scroll { flex: 1; overflow-y: auto; scrollbar-width: thin; scrollbar-color: var(--border-medium) transparent; }
        .new-chat-btn { margin: 10px 12px 6px; background: var(--accent-blue); color: #fff; border: none; border-radius: var(--radius-sm); padding: 8px 12px; font-size: 12px; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; width: calc(100% - 24px); transition: background 0.15s; }
        .new-chat-btn:hover { background: #1d4ed8; }
        .history-group-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.8px; padding: 10px 14px 4px; }
        .convo-item { padding: 8px 14px; cursor: pointer; border-left: 2px solid transparent; transition: all 0.15s; position: relative; }
        .convo-item:hover { background: var(--bg-secondary); }
        .convo-item.active { background: var(--accent-blue-dim); border-left-color: var(--accent-blue); }
        .convo-title { font-size: 12px; color: var(--text-secondary); line-height: 1.4; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 40px; }
        .convo-item.active .convo-title { color: var(--accent-blue); font-weight: 500; }
        .convo-date { font-size: 10px; color: var(--text-muted); margin-top: 1px; }
        .history-empty { font-size: 12px; color: var(--text-muted); font-style: italic; padding: 16px 14px; }
        .convo-actions { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); display: none; gap: 3px; }
        .convo-item:hover .convo-actions { display: flex; }
        .convo-action-btn { background: none; border: 1px solid var(--border-medium); border-radius: 3px; font-size: 10px; color: var(--text-muted); cursor: pointer; padding: 1px 5px; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .convo-action-btn:hover { background: var(--bg-tertiary); color: var(--text-primary); }
        .convo-action-btn.delete:hover { border-color: var(--accent-red-border); color: var(--accent-red); background: var(--accent-red-dim); }
        .convo-rename-input { font-size: 12px; color: var(--text-primary); background: var(--bg-primary); border: 1px solid var(--accent-blue); border-radius: 3px; padding: 1px 5px; width: calc(100% - 50px); font-family: 'DM Sans', sans-serif; }
        .convo-rename-input:focus { outline: none; }
        .sidebar-section { padding: 12px 14px; border-bottom: 1px solid var(--border-subtle); }
        .sidebar-section-title { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 9px; display: flex; align-items: center; justify-content: space-between; }


        /* Main Area */
        #main { flex: 1; display: flex; flex-direction: column; min-width: 0; min-height: 0; }
        #chat-header { padding: 11px 22px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: space-between; background: var(--bg-primary); }
        #chat-header-left { display: flex; align-items: center; gap: 9px; }
        .pulse-dot { width: 7px; height: 7px; background: var(--accent-green); border-radius: 50%; animation: pulse 2s infinite; flex-shrink: 0; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.4; } }
        #chat-header-label { font-size: 13px; color: var(--text-secondary); }
        .header-btns { display: flex; gap: 6px; }
        .header-btn { background: var(--bg-secondary); border: 1px solid var(--border-medium); color: var(--text-secondary); padding: 5px 11px; border-radius: var(--radius-sm); font-size: 12px; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.15s; }
        .header-btn:hover { background: var(--bg-tertiary); color: var(--text-primary); }
        #messages { flex: 1; overflow-y: auto; padding: 22px 30px; min-height: 0; display: flex; flex-direction: column; gap: 18px; scrollbar-width: thin; scrollbar-color: var(--border-medium) transparent; }
        .message { max-width: 820px; line-height: 1.7; font-size: 14px; animation: fadeIn 0.25s ease; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(5px); } to { opacity: 1; transform: translateY(0); } }
        .message.user { align-self: flex-end; background: var(--accent-blue); color: #fff; padding: 10px 15px; border-radius: var(--radius-lg) var(--radius-lg) 3px var(--radius-lg); font-size: 14px; }
        .message.assistant { align-self: flex-start; width: 100%; }
        .message.assistant .bubble { background: var(--bg-primary); border: 1px solid var(--border-subtle); padding: 18px 22px; border-radius: 3px var(--radius-lg) var(--radius-lg) var(--radius-lg); box-shadow: var(--shadow-sm); }
        .bubble h1 { font-size: 17px; font-weight: 700; color: var(--text-primary); margin: 18px 0 7px 0; letter-spacing: -0.3px; }
        .bubble h1:first-child { margin-top: 0; }
        .bubble h2 { font-size: 14px; font-weight: 600; color: var(--text-primary); margin: 16px 0 5px 0; padding-bottom: 5px; border-bottom: 1px solid var(--border-subtle); }
        .bubble h3 { font-size: 13px; font-weight: 600; color: var(--text-primary); margin: 12px 0 3px 0; }
        .bubble p { margin: 7px 0; color: var(--text-secondary); }
        .bubble strong { color: var(--text-primary); font-weight: 600; }
        .bubble ul, .bubble ol { margin: 7px 0; padding-left: 18px; color: var(--text-secondary); }
        .bubble li { margin: 3px 0; }
        .bubble code { font-family: 'JetBrains Mono', monospace; font-size: 12px; background: var(--bg-tertiary); border: 1px solid var(--border-subtle); padding: 1px 4px; border-radius: 3px; color: var(--accent-blue); }
        .bubble pre { background: var(--bg-secondary); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: 11px 14px; margin: 9px 0; overflow-x: auto; }
        .bubble pre code { background: none; border: none; padding: 0; color: var(--text-secondary); }
        .bubble hr { border: none; border-top: 1px solid var(--border-subtle); margin: 14px 0; }
        .bubble table { width: 100%; border-collapse: collapse; margin: 10px 0; font-size: 13px; }
        .bubble th { text-align: left; padding: 7px 11px; background: var(--bg-secondary); border: 1px solid var(--border-subtle); color: var(--text-primary); font-weight: 600; font-size: 10px; text-transform: uppercase; letter-spacing: 0.5px; }
        .bubble td { padding: 7px 11px; border: 1px solid var(--border-subtle); color: var(--text-secondary); }
        .bubble tr:hover td { background: var(--bg-secondary); }
        .chat-actions { display: flex; gap: 5px; flex-wrap: wrap; margin-top: 13px; padding-top: 13px; border-top: 1px solid var(--border-subtle); }
        .chat-task-card { background: var(--bg-secondary); border: 1px solid var(--border-subtle); border-left: 3px solid #eab308; border-radius: 6px; padding: 10px 14px 12px; margin: 4px 0 10px; }
        .chat-task-card.priority-critical { border-left-color: #ef4444; }
        .chat-task-card.priority-high { border-left-color: #f59e0b; }
        .chat-task-card.priority-medium { border-left-color: #3b82f6; }
        .chat-task-card .ctc-meta { font-size: 10px; color: var(--text-muted); margin-bottom: 4px; display: flex; align-items: center; gap: 6px; }
        .chat-task-card .ctc-title { font-size: 13px; font-weight: 600; color: var(--text-primary); line-height: 1.4; margin-bottom: 8px; }
        .chat-start-task-btn { display: inline-flex; align-items: center; gap: 6px; padding: 6px 14px; background: #16a34a; border: none; color: #fff; border-radius: 6px; font-size: 11px; font-family: 'DM Sans', sans-serif; font-weight: 700; cursor: pointer; transition: all 0.15s; box-shadow: 0 1px 4px rgba(22,163,74,0.3); letter-spacing: 0.01em; }
        .chat-start-task-btn:hover { background: #15803d; box-shadow: 0 2px 8px rgba(22,163,74,0.4); transform: translateY(-1px); }
        .chat-start-task-btn.started { background: #6b7280; cursor: default; box-shadow: none; transform: none; }
        .chat-task-inline-block { margin: 12px 0 4px; }

        /* ── Collapsible sections ── */
        .collapsible-section { margin: 10px 0; border: 1px solid var(--border-subtle); border-radius: 8px; overflow: hidden; }
        .collapsible-toggle { width: 100%; background: var(--bg-secondary); border: none; padding: 10px 14px; cursor: pointer; display: flex; align-items: center; gap: 8px; text-align: left; font-family: 'DM Sans', sans-serif; }
        .collapsible-toggle:hover { background: var(--bg-tertiary); }
        .collapsible-heading { font-size: 13px; font-weight: 700; color: var(--text-primary); flex-shrink: 0; }
        .collapsible-preview { font-size: 11px; color: var(--text-muted); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
        .collapsible-arrow { font-size: 9px; color: var(--text-muted); flex-shrink: 0; transition: transform 0.2s; }
        .collapsible-body { padding: 12px 14px; background: var(--bg-primary); border-top: 1px solid var(--border-subtle); }
        .collapsible-section.collapsed .collapsible-body { display: none; }
        .collapsible-section.collapsed .collapsible-preview { display: inline; }
        .collapsible-section:not(.collapsed) .collapsible-preview { display: none; }

        /* ── Play header card ── */
        .play-header-bubble { background: linear-gradient(135deg, var(--bg-secondary) 0%, var(--accent-blue-dim) 100%) !important; border-color: var(--accent-blue-border) !important; }
        .play-header-meta { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
        .play-header-hours { font-size: 11px; color: var(--text-muted); background: var(--bg-tertiary); padding: 2px 7px; border-radius: 4px; }
        .play-header-assigned { font-size: 11px; color: var(--text-secondary); }
        .play-header-title { font-size: 16px; font-weight: 700; color: var(--text-primary); margin-bottom: 8px; line-height: 1.3; }
        .play-header-hint { font-size: 12px; color: var(--text-muted); font-style: italic; padding-top: 8px; border-top: 1px solid var(--border-subtle); }
        .chat-btn { background: var(--bg-secondary); border: 1px solid var(--border-medium); color: var(--text-secondary); padding: 5px 11px; border-radius: var(--radius-sm); font-size: 11px; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.15s; }
        .chat-btn:hover { background: var(--bg-tertiary); color: var(--text-primary); border-color: var(--border-accent); }
        .typing-indicator { display: none; align-self: flex-start; padding: 6px 16px 10px; max-width: 480px; }
        .thinking-bubble { background: var(--bg-secondary); border: 1px solid var(--border-subtle); border-radius: 0 12px 12px 12px; padding: 10px 16px; display: flex; align-items: center; gap: 10px; }
        .thinking-text { font-size: 12px; color: var(--text-muted); font-style: italic; font-family: 'DM Sans', sans-serif; }
        .thinking-bar { width: 80px; height: 3px; background: var(--border-medium); border-radius: 2px; overflow: hidden; }
        .thinking-bar-fill { height: 100%; width: 40%; background: var(--accent-blue); border-radius: 2px; animation: thinking-slide 1.4s ease-in-out infinite; }
        @keyframes thinking-slide { 0% { transform: translateX(-100%); } 50% { transform: translateX(150%); } 100% { transform: translateX(-100%); } }
        .typing-dots span:nth-child(2) { animation-delay: 0.15s; }
        .typing-dots span:nth-child(3) { animation-delay: 0.3s; }
        @keyframes bounce { 0%, 60%, 100% { transform: translateY(0); opacity: 0.4; } 30% { transform: translateY(-4px); opacity: 1; } }
        #input-area { padding: 13px 30px 17px; border-top: 1px solid var(--border-subtle); display: flex; gap: 9px; background: var(--bg-primary); }
        #input { flex: 1; background: var(--bg-secondary); border: 1px solid var(--border-medium); border-radius: var(--radius-md); padding: 11px 14px; color: var(--text-primary); font-size: 14px; resize: none; height: 46px; line-height: 24px; font-family: 'DM Sans', sans-serif; transition: border-color 0.15s; }
        #input:focus { outline: none; border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
        #input::placeholder { color: var(--text-muted); }
        #send { background: var(--accent-blue); border: none; color: #fff; padding: 0 18px; border-radius: var(--radius-md); cursor: pointer; font-size: 13px; font-weight: 600; font-family: 'DM Sans', sans-serif; transition: background 0.15s; }
        #send:hover { background: #1d4ed8; }
        #send:disabled { opacity: 0.4; cursor: not-allowed; }

        /* Review Card */
        .review-card { background: var(--bg-secondary); border: 1px solid var(--accent-blue-border); border-radius: var(--radius-md); padding: 16px 18px; margin-top: 14px; }
        .review-card-header { display: flex; align-items: center; gap: 8px; margin-bottom: 12px; }
        .review-card-title { font-size: 12px; font-weight: 700; color: var(--accent-blue); text-transform: uppercase; letter-spacing: 0.5px; }
        .review-card-sub { font-size: 11px; color: var(--text-muted); }
        .review-criteria { font-size: 12px; color: var(--text-secondary); margin-bottom: 14px; line-height: 1.5; }
        .review-findings { margin-bottom: 12px; }
        .review-finding-row { display: flex; align-items: flex-start; gap: 8px; padding: 6px 8px; border-radius: var(--radius-sm); font-size: 13px; color: var(--text-primary); border-bottom: 1px solid var(--border-subtle); line-height: 1.4; }
        .review-finding-row:last-child { border-bottom: none; }
        .review-finding-bullet { color: var(--accent-yellow); font-size: 13px; flex-shrink: 0; margin-top: 1px; }
        .review-row { display: flex; gap: 8px; margin-bottom: 8px; align-items: flex-start; }
        .review-row label { font-size: 11px; font-weight: 600; color: var(--text-primary); width: 120px; flex-shrink: 0; padding-top: 2px; }
        .review-radio-group { display: flex; gap: 6px; }
        .review-radio-btn { padding: 3px 10px; border-radius: 4px; border: 1px solid var(--border-medium); background: var(--bg-primary); color: var(--text-secondary); font-size: 11px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .review-radio-btn:hover { border-color: var(--border-accent); }
        .review-radio-btn.selected.agree { background: var(--accent-green-dim); border-color: var(--accent-green-border); color: var(--accent-green); }
        .review-radio-btn.selected.disagree { background: var(--accent-red-dim); border-color: var(--accent-red-border); color: var(--accent-red); }
        .review-correction-list { display: flex; flex-direction: column; gap: 6px; margin-top: 8px; }
        .review-correction-row { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
        .review-correction-input { flex: 1; min-width: 120px; background: var(--bg-primary); border: 1px solid var(--border-medium); border-radius: 4px; padding: 4px 8px; font-size: 11px; color: var(--text-primary); font-family: 'DM Sans', sans-serif; }
        .review-correction-input:focus { outline: none; border-color: var(--accent-blue); }
        .review-correction-select { background: var(--bg-primary); border: 1px solid var(--border-medium); border-radius: 4px; padding: 4px 8px; font-size: 11px; color: var(--text-primary); font-family: 'DM Sans', sans-serif; cursor: pointer; }
        .review-add-correction { font-size: 11px; color: var(--accent-blue); cursor: pointer; padding: 3px 0; border: none; background: none; font-family: 'DM Sans', sans-serif; }
        .review-add-correction:hover { text-decoration: underline; }
        .review-remove-btn { font-size: 11px; color: var(--text-muted); border: none; background: none; cursor: pointer; padding: 2px 5px; }
        .review-divider { border: none; border-top: 1px solid var(--border-subtle); margin: 12px 0; }
        .review-missing { width: 100%; background: var(--bg-primary); border: 1px solid var(--border-medium); border-radius: 4px; padding: 6px 10px; font-size: 12px; color: var(--text-primary); font-family: 'DM Sans', sans-serif; resize: vertical; min-height: 48px; }
        .review-missing:focus { outline: none; border-color: var(--accent-blue); }
        .review-verdict-group { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 4px; }
        .review-verdict-btn { padding: 5px 12px; border-radius: 4px; border: 1px solid var(--border-medium); background: var(--bg-primary); color: var(--text-secondary); font-size: 11px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .review-verdict-btn:hover { border-color: var(--border-accent); }
        .review-verdict-btn.selected { background: var(--accent-blue); border-color: var(--accent-blue); color: #fff; }
        .review-submit-btn { background: var(--accent-blue); border: none; color: #fff; padding: 7px 18px; border-radius: var(--radius-sm); font-size: 12px; font-weight: 600; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: background 0.15s; margin-top: 12px; }
        .review-submit-btn:hover { background: #1d4ed8; }
        .review-submitted { font-size: 12px; color: var(--accent-green); font-weight: 600; margin-top: 10px; }

        /* Right Tasks Panel */
        #right-panel { width: 280px; min-width: 280px; background: var(--bg-primary); border-left: 1px solid var(--border-subtle); display: none; flex-direction: column; overflow: hidden; transition: all 0.2s ease; }
        #right-panel.open { display: flex; }
        #tasks-toggle-btn { background: var(--bg-secondary); border: 1px solid var(--border-medium); border-radius: var(--radius-sm); padding: 5px 10px; font-size: 11px; color: var(--text-secondary); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; display: flex; align-items: center; gap: 5px; }
        #tasks-toggle-btn:hover { background: var(--bg-tertiary); color: var(--text-primary); }
        #tasks-toggle-btn.active { background: var(--accent-blue-dim); border-color: var(--accent-blue-border); color: var(--accent-blue); }
        #right-panel-header { padding: 11px 14px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: space-between; background: var(--bg-primary); }
        #right-panel-header span { font-size: 13px; font-weight: 600; color: var(--text-primary); }
        #right-panel-body { display: flex; flex-direction: column; flex: 1; overflow: hidden; }
        .right-stats { display: flex; gap: 5px; padding: 10px 12px; border-bottom: 1px solid var(--border-subtle); }
        .task-stat { flex: 1; background: var(--bg-secondary); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); padding: 7px; text-align: center; }
        .task-stat-number { font-size: 16px; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
        .task-stat-number.urgent { color: var(--accent-red); }
        .task-stat-number.active { color: var(--accent-yellow); }
        .task-stat-number.done { color: var(--accent-green); }
        .task-stat-label { font-size: 9px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-top: 1px; }
        .right-filters { display: flex; gap: 4px; padding: 8px 12px; border-bottom: 1px solid var(--border-subtle); flex-wrap: wrap; }
        .right-filter-btn { font-size: 10px; padding: 3px 9px; border-radius: 4px; border: 1px solid var(--border-medium); background: var(--bg-secondary); color: var(--text-muted); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .right-filter-btn:hover { color: var(--text-secondary); border-color: var(--border-accent); }
        .right-filter-btn.active { background: var(--accent-blue-dim); border-color: var(--accent-blue-border); color: var(--accent-blue); font-weight: 600; }
        #right-task-list { overflow-y: auto; flex: 1; padding: 8px 10px; scrollbar-width: thin; scrollbar-color: var(--border-medium) transparent; }
        .task-item { padding: 9px 11px; background: var(--bg-primary); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); margin-bottom: 5px; cursor: pointer; transition: border-color 0.15s; }
        .task-item:hover { border-color: var(--accent-blue-border); }
        .task-item.selected { border-color: var(--accent-blue) !important; background: var(--accent-blue-dim) !important; box-shadow: 0 0 0 2px rgba(37,99,235,0.15); }
        .task-item.selected::before { content: '\25B6  '; color: var(--accent-blue); font-size: 9px; }
        .task-item-header { display: flex; align-items: center; gap: 5px; margin-bottom: 3px; }
        .task-priority { font-size: 9px; font-weight: 600; padding: 1px 5px; border-radius: 3px; text-transform: uppercase; letter-spacing: 0.5px; }
        .task-priority.urgent { background: var(--accent-red-dim); color: var(--accent-red); border: 1px solid var(--accent-red-border); }
        .task-priority.high { background: var(--accent-yellow-dim); color: var(--accent-yellow); border: 1px solid var(--accent-yellow-border); }
        .task-priority.medium { background: var(--accent-blue-dim); color: var(--accent-blue); border: 1px solid var(--accent-blue-border); }
        .task-priority.low { background: var(--bg-secondary); color: var(--text-muted); border: 1px solid var(--border-subtle); }
        .task-assignee { font-size: 10px; color: var(--text-muted); margin-left: auto; }
        .task-title { font-size: 11px; color: var(--text-secondary); line-height: 1.4; }
        .task-meta { display: flex; gap: 7px; margin-top: 5px; align-items: center; }
        .task-hours { font-size: 10px; color: var(--text-muted); font-family: 'JetBrains Mono', monospace; }
        .task-status-badge { font-size: 9px; padding: 1px 5px; border-radius: 3px; background: var(--bg-tertiary); color: var(--text-muted); border: 1px solid var(--border-subtle); }
        .task-status-badge.in_progress { background: var(--accent-yellow-dim); color: var(--accent-yellow); border-color: var(--accent-yellow-border); }
        .task-actions-row { display: flex; gap: 3px; margin-top: 5px; }
        .task-action-btn { font-size: 10px; padding: 2px 7px; border-radius: 3px; border: 1px solid var(--border-subtle); background: var(--bg-secondary); color: var(--text-muted); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .task-action-btn:hover { border-color: var(--border-accent); color: var(--text-secondary); }
        .task-action-btn.complete:hover { border-color: var(--accent-green-border); color: var(--accent-green); background: var(--accent-green-dim); }
        .task-action-btn.start:hover { border-color: var(--accent-yellow-border); color: var(--accent-yellow); background: var(--accent-yellow-dim); }
        .task-empty { font-size: 12px; color: var(--text-muted); font-style: italic; padding: 4px 0; }

        /* Task Detail Slide-over */
        #task-detail-panel { display: none; position: fixed; top: 0; right: 280px; width: 360px; height: 100vh; background: var(--bg-primary); border-left: 1px solid var(--border-subtle); flex-direction: column; overflow: hidden; z-index: 50; box-shadow: -4px 0 16px rgba(0,0,0,0.08); }
        #task-detail-panel.open { display: flex; }
        .panel-header { padding: 14px 18px; border-bottom: 1px solid var(--border-subtle); display: flex; align-items: center; justify-content: space-between; }
        .panel-header h3 { font-size: 13px; font-weight: 600; }
        .panel-close { background: none; border: none; font-size: 17px; color: var(--text-muted); cursor: pointer; padding: 3px 7px; border-radius: 4px; transition: all 0.15s; }
        .panel-close:hover { background: var(--bg-tertiary); color: var(--text-primary); }
        .panel-body { flex: 1; overflow-y: auto; padding: 14px 18px; }
        .panel-field { margin-bottom: 12px; }
        .panel-label { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px; }
        .panel-value { font-size: 12px; color: var(--text-secondary); line-height: 1.5; }
        .time-log-row { display: flex; gap: 5px; align-items: center; margin-top: 7px; }
        .time-log-input { width: 56px; background: var(--bg-secondary); border: 1px solid var(--border-medium); border-radius: 4px; padding: 4px 7px; font-size: 12px; color: var(--text-primary); font-family: 'JetBrains Mono', monospace; text-align: center; }
        .time-log-input:focus { outline: none; border-color: var(--accent-blue); }
        .time-log-btn { font-size: 11px; padding: 4px 9px; border-radius: 4px; background: var(--accent-blue-dim); border: 1px solid var(--accent-blue-border); color: var(--accent-blue); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .time-log-btn:hover { background: var(--accent-blue); color: #fff; }
        .panel-chat { border-top: 1px solid var(--border-subtle); padding: 11px 18px; }
        .panel-chat-title { font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 7px; }
        .panel-chat-input-row { display: flex; gap: 5px; }
        .panel-chat-input { flex: 1; background: var(--bg-secondary); border: 1px solid var(--border-medium); border-radius: 5px; padding: 7px 10px; font-size: 12px; color: var(--text-primary); font-family: 'DM Sans', sans-serif; }
        .panel-chat-input:focus { outline: none; border-color: var(--accent-blue); }
        .panel-chat-send { font-size: 11px; padding: 7px 11px; border-radius: 5px; background: var(--accent-blue); border: none; color: #fff; cursor: pointer; font-family: 'DM Sans', sans-serif; }
        .panel-chat-messages { max-height: 180px; overflow-y: auto; margin-bottom: 7px; }
        .panel-chat-msg { font-size: 11px; margin-bottom: 5px; line-height: 1.5; }
        .panel-chat-msg.ai { color: var(--text-secondary); background: var(--bg-secondary); padding: 7px 9px; border-radius: 5px; border: 1px solid var(--border-subtle); }
        .panel-chat-msg.user-msg { color: var(--accent-blue); text-align: right; }

        /* Recheck item layout */
        .recheck-item { padding: 8px 10px; background: var(--bg-primary); border: 1px solid var(--border-subtle); border-radius: var(--radius-sm); margin-bottom: 5px; }
        .recheck-item-main { display: flex; flex-direction: column; gap: 3px; }
        .recheck-info { font-size: 11px; color: var(--text-secondary); font-weight: 500; line-height: 1.4; }
        .recheck-criteria-text { font-size: 10px; color: var(--text-muted); font-style: italic; line-height: 1.4; }
        .recheck-controls { display: flex; align-items: center; gap: 4px; margin-top: 3px; flex-wrap: wrap; }
        .recheck-date { font-size: 10px; font-family: 'JetBrains Mono', monospace; padding: 2px 5px; border-radius: 3px; flex-shrink: 0; }
        .recheck-date.overdue { background: var(--accent-red-dim); color: var(--accent-red); }
        .recheck-date.upcoming { background: var(--accent-yellow-dim); color: var(--accent-yellow); }
        .recheck-edit-btn { background: none; border: 1px solid var(--border-medium); border-radius: 3px; font-size: 10px; color: var(--text-muted); cursor: pointer; padding: 1px 5px; font-family: 'DM Sans', sans-serif; transition: all 0.15s; }
        .recheck-edit-btn:hover { background: var(--bg-tertiary); color: var(--text-primary); }
        .recheck-verify-btn { font-size: 9px; padding: 2px 6px; border-radius: 3px; border: 1px solid var(--accent-green-border); background: var(--accent-green-dim); color: var(--accent-green); cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.15s; margin-left: auto; }
        .recheck-verify-btn:hover { background: var(--accent-green); color: #fff; }

        /* Modal */
        .modal-overlay { display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.3); z-index: 100; align-items: center; justify-content: center; }
        .modal-overlay.active { display: flex; }
        .modal { background: var(--bg-primary); border: 1px solid var(--border-subtle); border-radius: 12px; padding: 22px; width: 400px; max-width: 90vw; box-shadow: 0 8px 30px rgba(0,0,0,0.12); }
        .modal h3 { font-size: 15px; font-weight: 600; margin-bottom: 14px; }
        .modal-field { margin-bottom: 11px; }
        .modal-field label { display: block; font-size: 10px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px; }
        .modal-field input, .modal-field select, .modal-field textarea { width: 100%; background: var(--bg-secondary); border: 1px solid var(--border-medium); border-radius: 5px; padding: 7px 11px; color: var(--text-primary); font-size: 13px; font-family: 'DM Sans', sans-serif; }
        .modal-field textarea { height: 56px; resize: vertical; }
        .modal-field input:focus, .modal-field select:focus, .modal-field textarea:focus { outline: none; border-color: var(--accent-blue); }
        .modal-btns { display: flex; gap: 7px; justify-content: flex-end; margin-top: 14px; }
        .modal-btn { padding: 7px 14px; border-radius: 5px; font-size: 13px; font-weight: 500; font-family: 'DM Sans', sans-serif; cursor: pointer; transition: all 0.15s; }
        .modal-btn.cancel { background: var(--bg-secondary); border: 1px solid var(--border-medium); color: var(--text-secondary); }
        .modal-btn.cancel:hover { background: var(--bg-tertiary); }
        .modal-btn.save { background: var(--accent-blue); border: none; color: #fff; }
        .modal-btn.save:hover { background: #1d4ed8; }

        @media (max-width: 768px) {
            #sidebar { display: none; }
            #right-panel { display: none; }
            #task-detail-panel { display: none !important; }
            #messages { padding: 14px; }
            #input-area { padding: 11px 14px; }
        }
    </style>
</head>
<body>

<!-- Left Sidebar -->
<div id="sidebar">
    <div id="sidebar-header">
        <h1>Logiri</h1>
        <p>SEO Intelligence · Double D Trailers</p>
    </div>
    <div class="user-card">
        <div class="user-avatar">{{ userName[:2]|upper }}</div>
        <div class="user-info">
            <div class="user-name">{{ userName }}</div>
            <div class="user-role">{{ userRole }}</div>
        </div>
        <a href="{{ logout_path() }}" class="user-logout">Logout</a>
    </div>
    <div class="sidebar-tabs">
        <div class="sidebar-tab active" id="tab-history" onclick="switchTab('history')">History</div>
        <div class="sidebar-tab" id="tab-rechecks" onclick="switchTab('rechecks')">Rechecks</div>
    </div>
    <div id="sidebar-scroll">
        <div id="panel-history">
            <button class="new-chat-btn" onclick="newChat()">+ New Chat</button>
            <div id="history-list">
                {% if conversations is empty %}
                    <div class="history-empty">No conversations yet. Start chatting!</div>
                {% else %}
                    <div class="history-group-label">Recent</div>
                    {% for convo in conversations %}
                        <div class="convo-item" id="convo-{{ convo.id }}" onclick="loadConversation({{ convo.id }})">
                            <div class="convo-title">{{ convo.title ?? 'Conversation #' ~ convo.id }}</div>
                            <div class="convo-date">{{ convo.updated_at|date('M j') }}</div>
                            <div class="convo-actions">
                                <button class="convo-action-btn" onclick="event.stopPropagation(); startRename({{ convo.id }})">✎</button>
                                <button class="convo-action-btn delete" onclick="event.stopPropagation(); deleteConvo({{ convo.id }})">✕</button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
        <div id="panel-rechecks" style="display:none;">
            <div class="sidebar-section" style="border-bottom:none;">
                <div class="sidebar-section-title">Pending Rechecks</div>
                <div id="recheck-list">
                    {% if rechecks is empty %}
                        <div class="task-empty">No rechecks pending</div>
                    {% else %}
                        {% for r in rechecks %}
                        <div class="recheck-item">
                            <div class="recheck-item-main">
                                <div class="recheck-info">{{ r.title }}</div>
                                {% if r.recheck_criteria %}<div class="recheck-criteria-text">&#10003; {{ r.recheck_criteria }}</div>{% endif %}
                                <div class="recheck-controls">
                                    <span class="recheck-date upcoming" id="rdate-{{ r.id }}">{{ r.recheck_date }}</span>
                                    <button class="recheck-edit-btn" onclick="editRecheckDate({{ r.id }}, '{{ r.recheck_date }}')">&#x270E;</button>
                                    <button class="recheck-verify-btn" onclick="verifyRecheck({{ r.id }})">Verify</button>
                                </div>
                            </div>
                        </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Add Task Modal -->
<div class="modal-overlay" id="add-task-modal">
    <div class="modal">
        <h3>Add Task</h3>
        <div class="modal-field"><label>Title</label><input type="text" id="new-task-title" placeholder="Task description..."></div>
        <div class="modal-field"><label>Assigned To</label><select id="new-task-assignee"><option value="Brook">Brook (SEO + Content)</option><option value="Jeanne">Jeanne (Content Director)</option><option value="Kalib">Kalib (Sales)</option><option value="Brad">Brad (Marketing)</option></select></div>
        <div class="modal-field"><label>Priority</label><select id="new-task-priority"><option value="high">High</option><option value="medium" selected>Medium</option><option value="urgent">Urgent</option><option value="low">Low</option></select></div>
        <div class="modal-field"><label>Est. Hours</label><input type="number" id="new-task-hours" value="1" min="0.5" step="0.5"></div>
        <div class="modal-field"><label>Recheck Type</label><select id="new-task-recheck"><option value="">None</option><option value="cannibalization_fix">Cannibalization (14d)</option><option value="intent_mismatch">Intent Mismatch (14d)</option><option value="ranking_drop">Ranking Drop (28d)</option><option value="404_fix">404 Fix (7d)</option><option value="sitemap_fix">Sitemap Fix (7d)</option></select></div>
        <div class="modal-btns"><button class="modal-btn cancel" onclick="closeAddTask()">Cancel</button><button class="modal-btn save" onclick="saveNewTask()">Add Task</button></div>
    </div>
</div>

<!-- Main Chat -->
<div id="main">
    <div id="chat-header">
        <div id="chat-header-left">
            <div class="pulse-dot"></div>
            <span id="chat-header-label">Logiri is online</span>
        </div>
        <div class="header-btns">
            <button id="tasks-toggle-btn" onclick="toggleTasksPanel()">&#9776; Tasks</button>
            <button class="header-btn" onclick="newChat()">+ New Chat</button>
        </div>
    </div>
    <div id="messages"></div>
    <div class="typing-indicator" id="typing"><div class="thinking-bubble"><div class="thinking-bar"><div class="thinking-bar-fill"></div></div><span class="thinking-text">Logiri is thinking…</span></div></div>
    <div id="input-area">
        <textarea id="input" placeholder="Ask Logiri about your SEO, tasks, or priorities..." rows="1"></textarea>
        <button id="send">Send</button>
    </div>
</div>

<!-- Right Tasks Panel -->
<div id="right-panel">
    <div id="right-panel-header">
        <span>Tasks</span>
        <button class="task-action-btn" onclick="openAddTask()">+ Add</button>
    </div>
    <div id="right-panel-body">
        <div class="right-stats">
            <div class="task-stat"><div class="task-stat-number urgent" id="count-urgent">{{ taskCounts.urgent }}</div><div class="task-stat-label">High+</div></div>
            <div class="task-stat"><div class="task-stat-number active" id="count-active">{{ taskCounts.active }}</div><div class="task-stat-label">Active</div></div>
            <div class="task-stat"><div class="task-stat-number done" id="count-done">{{ taskCounts.done }}</div><div class="task-stat-label">Done</div></div>
        </div>
        <div class="right-filters">
            <button class="right-filter-btn active" id="filter-mine" onclick="setTaskFilter('mine')">My Tasks</button>
            <button class="right-filter-btn" id="filter-team" onclick="setTaskFilter('team')">Team</button>
            <button class="right-filter-btn" id="filter-wins" onclick="setTaskFilter('wins')">Quick Wins</button>
            <button class="right-filter-btn" id="filter-all" onclick="setTaskFilter('all')">All</button>
        </div>
        <div id="right-task-list">
            {% if tasks is empty %}
                <div class="task-empty">No active tasks. Ask Logiri for a briefing.</div>
            {% else %}
                {% for task in tasks %}
                <div class="task-item" id="task-{{ task.id }}"
                     data-assignee="{{ task.assigned_to ?? '' }}"
                     data-hours="{{ task.estimated_hours ?? 99 }}"
                     onclick="openTaskDetail({{ task.id }})">
                    <div class="task-item-header">
                        <span class="task-priority {{ task.priority }}">{{ task.priority }}</span>
                        <span class="task-assignee">{{ task.assigned_to ?? 'Unassigned' }}</span>
                    </div>
                    <div class="task-title">{{ task.title }}</div>
                    <div class="task-meta">
                        <span class="task-hours">{{ task.estimated_hours ?? '?' }}h</span>
                        <span class="task-status-badge {{ task.status }}">{{ task.status }}</span>
                    </div>
                    <div class="task-actions-row">
                        {% if task.status == 'pending' %}<button class="task-action-btn start" onclick="event.stopPropagation(); startTask({{ task.id }})">&#9654; Start</button>{% endif %}
                        {% if task.status != 'done' %}<button class="task-action-btn complete" onclick="event.stopPropagation(); completeTask({{ task.id }})">&#10003; Done</button>{% endif %}
                    </div>
                </div>
                {% endfor %}
            {% endif %}
        </div>
    </div>
</div>

<!-- Recheck Confirmation Modal -->
<div class="modal-overlay" id="recheck-confirm-modal">
    <div class="modal">
        <h3>&#10003; Mark Task Complete</h3>
        <input type="hidden" id="recheck-modal-taskid">
        <p style="font-size:12px;color:var(--text-secondary);margin-bottom:14px;" id="recheck-modal-title"></p>
        <div class="modal-field">
            <label>Recheck in how many days?</label>
            <input type="number" id="recheck-modal-days" value="14" min="1" max="90" step="1">
        </div>
        <div class="modal-field">
            <label>What must pass on next crawl?</label>
            <textarea id="recheck-modal-criteria" placeholder="e.g. h1_matches_title = TRUE for /url/ — or leave blank to auto-detect from task description" style="height:70px;resize:vertical;"></textarea>
        </div>
        <div class="modal-btns">
            <button class="modal-btn cancel" onclick="document.getElementById('recheck-confirm-modal').classList.remove('active')">Cancel</button>
            <button class="modal-btn save" onclick="confirmComplete()">Done &#8594; Set Recheck</button>
        </div>
    </div>
</div>

<!-- Task Detail Slide-over -->
<div id="task-detail-panel">
    <div class="panel-header">
        <h3 id="panel-title">Task Detail</h3>
        <button class="panel-close" onclick="closeTaskDetail()">&#x2715;</button>
    </div>
    <div class="panel-body" id="panel-body"></div>
    <div class="panel-chat">
        <div class="panel-chat-title">Ask AI about this task</div>
        <div class="panel-chat-messages" id="panel-chat-messages"></div>
        <div class="panel-chat-input-row">
            <input type="text" class="panel-chat-input" id="panel-chat-input" placeholder="Ask about this task...">
            <button class="panel-chat-send" onclick="sendTaskChat()">Ask</button>
        </div>
    </div>
</div>

<script>
    try { marked.setOptions({ breaks: true, gfm: true }); } catch(e) {}

    const USER_NAME = '{{ userName }}';
    const USER_ROLE = '{{ userRole }}';

    let messages         = [];
    let conversationId   = null;
    let currentTaskId    = null;
    let taskChatMessages = [];
    let activeSidebarTab = 'history';
    let activeTaskFilter = 'mine';

    const messagesEl = document.getElementById('messages');
    const inputEl    = document.getElementById('input');
    const sendEl     = document.getElementById('send');
    const typingEl   = document.getElementById('typing');

    // Sidebar Tabs (History + Rechecks only)
    function switchTab(tab) {
        activeSidebarTab = tab;
        ['history','rechecks'].forEach(t => {
            document.getElementById('tab-' + t).classList.toggle('active', t === tab);
            document.getElementById('panel-' + t).style.display = t === tab ? 'block' : 'none';
        });
    }

    // Task Filter
    function setTaskFilter(filter) {
        activeTaskFilter = filter;
        ['mine','team','wins','all'].forEach(f => {
            const btn = document.getElementById('filter-' + f);
            if (btn) btn.classList.toggle('active', f === filter);
        });
        document.querySelectorAll('#right-task-list .task-item').forEach(el => {
            const assignee = el.dataset.assignee || '';
            const hours    = parseFloat(el.dataset.hours) || 99;
            let show = true;
            if (filter === 'mine')  show = assignee === USER_NAME;
            if (filter === 'wins')  show = hours <= 2;
            el.style.display = show ? '' : 'none';
        });
    }

    // Conversation History
    function setActiveConvo(id) {
        document.querySelectorAll('.convo-item').forEach(el => el.classList.remove('active'));
        const el = document.getElementById('convo-' + id);
        if (el) el.classList.add('active');
    }

    async function loadConversation(id) {
        conversationId = id;
        setActiveConvo(id);
        messages = [];
        messagesEl.innerHTML = '';
        const res  = await fetch('/api/conversations/' + id + '/messages');
        const msgs = await res.json();
        msgs.forEach(msg => {
            messages.push({ role: msg.role, content: msg.content });
            appendMessage(msg.role, msg.content);
        });
        const convoEl = document.getElementById('convo-' + id);
        const title   = convoEl ? convoEl.querySelector('.convo-title').textContent : 'Conversation';
        document.getElementById('chat-header-label').textContent = title;
        inputEl.focus();
    }

    function newChat() {
        conversationId = null;
        messages       = [];
        messagesEl.innerHTML = '';
        document.querySelectorAll('.convo-item').forEach(el => el.classList.remove('active'));
        document.getElementById('chat-header-label').textContent = 'Logiri is online';
        requestBriefing();
        switchTab('history');
    }

    function addConvoToSidebar(id, title) {
        const list  = document.getElementById('history-list');
        const empty = list.querySelector('.history-empty');
        if (empty) empty.remove();
        if (!list.querySelector('.history-group-label')) {
            const label = document.createElement('div');
            label.className   = 'history-group-label';
            label.textContent = 'Recent';
            list.insertBefore(label, list.firstChild);
        }
        if (document.getElementById('convo-' + id)) { setActiveConvo(id); return; }
        const div = document.createElement('div');
        div.className = 'convo-item active';
        div.id        = 'convo-' + id;
        div.onclick   = () => loadConversation(id);
        div.innerHTML = '<div class="convo-title">' + escapeHtml(title) + '</div>' +
                        '<div class="convo-date">Just now</div>' +
                        '<div class="convo-actions">' +
                        '<button class="convo-action-btn" onclick="event.stopPropagation();startRename(' + id + ')">&#x270E;</button>' +
                        '<button class="convo-action-btn delete" onclick="event.stopPropagation();deleteConvo(' + id + ')">&#x2715;</button>' +
                        '</div>';
        const label = list.querySelector('.history-group-label');
        label ? label.after(div) : list.insertBefore(div, list.firstChild);
        setActiveConvo(id);
    }

    // Rename Conversation
    function startRename(id) {
        const convoEl = document.getElementById('convo-' + id);
        if (!convoEl) return;
        const titleEl = convoEl.querySelector('.convo-title');
        const current = titleEl.textContent.trim();
        const input   = document.createElement('input');
        input.type      = 'text';
        input.className = 'convo-rename-input';
        input.value     = current;
        titleEl.replaceWith(input);
        input.focus();
        input.select();
        const finish = async () => {
            const newTitle = input.value.trim();
            if (newTitle && newTitle !== current) {
                await fetch('/api/conversations/' + id + '/rename', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ title: newTitle })
                });
                if (conversationId == id) document.getElementById('chat-header-label').textContent = newTitle;
                const div = document.createElement('div');
                div.className = 'convo-title';
                div.textContent = newTitle;
                input.replaceWith(div);
            } else {
                const div = document.createElement('div');
                div.className = 'convo-title';
                div.textContent = current;
                input.replaceWith(div);
            }
        };
        input.addEventListener('blur', finish);
        input.addEventListener('keydown', e => {
            if (e.key === 'Enter')  { e.preventDefault(); input.blur(); }
            if (e.key === 'Escape') { input.value = current; input.blur(); }
        });
    }

    // Delete Conversation
    async function deleteConvo(id) {
        if (!confirm('Delete this conversation? This cannot be undone.')) return;
        await fetch('/api/conversations/' + id + '/delete', { method: 'POST' });
        const el = document.getElementById('convo-' + id);
        if (el) el.remove();
        if (conversationId == id) {
            conversationId = null;
            messages = [];
            messagesEl.innerHTML = '';
            document.getElementById('chat-header-label').textContent = 'Logiri is online';
        }
        showNotification('Conversation deleted', 'green');
    }

    // Main Chat
    async function sendMessage(text) {
        messages.push({ role: 'user', content: text });
        appendMessage('user', text);
        inputEl.value          = '';
        sendEl.disabled        = true;
        typingEl.style.display = 'block';
        messagesEl.scrollTop   = messagesEl.scrollHeight;
        try {
            const res  = await fetch('/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages, conversation_id: conversationId })
            });
            const data  = await res.json();
            const reply = data.response || data.error || 'No response.';
            if (data.conversation_id) {
                const isNew = !conversationId;
                conversationId = data.conversation_id;
                if (isNew) addConvoToSidebar(conversationId, text.length > 50 ? text.substring(0, 47) + '...' : text);
            }
            messages.push({ role: 'assistant', content: reply });
            appendMessage('assistant', reply);
            if (data.tasks_created && data.tasks_created.length > 0) {
                await refreshTasksPanel();
                showNotification('&#10003; ' + data.tasks_created.length + ' task' + (data.tasks_created.length > 1 ? 's' : '') + ' created', 'green');
                appendTaskCards(data.tasks_created);
            }
        } catch (e) {
            appendMessage('assistant', 'Error reaching Logiri. Please try again.');
        }
        typingEl.style.display = 'none';
        sendEl.disabled        = false;
        inputEl.focus();
    }

    function appendMessage(role, text) {
        const div = document.createElement('div');
        div.className = 'message ' + role;
        if (role === 'assistant') {
            const bubble = document.createElement('div');
            bubble.className  = 'bubble';
            const processed   = processReviewCards(text, bubble);
            bubble.innerHTML  = marked.parse(processed);
            renderPendingReviewCards(bubble);
            makeCollapsible(bubble);
            div.appendChild(bubble);
            if (text.length > 200) {
                const actions = document.createElement('div');
                actions.className = 'chat-actions';
                actions.innerHTML =
                    '<button class="chat-btn" onclick="sendMessage(\'What should ' + USER_NAME + ' work on today?\')">&#x1F4CB; My Tasks</button>' +
                    '<button class="chat-btn" onclick="sendMessage(\'Show team status and blockers\')">&#x1F465; Team Status</button>' +
                    '<button class="chat-btn" onclick="sendMessage(\'Quick wins under 2 hours\')">&#x26A1; Quick Wins</button>' +
                    '<button class="chat-btn" onclick="sendMessage(\'What rechecks are due?\')">&#x1F504; Rechecks</button>' +
                    '<button class="chat-btn" onclick="openAddTask()">+ Add Task</button>';
                bubble.appendChild(actions);
            }
        } else {
            div.textContent = text;
        }
        messagesEl.appendChild(div);
        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    // Review Card Processing
    let pendingReviewCards = [];

    function processReviewCards(text, bubble) {
        pendingReviewCards = [];
        const cardRegex = /<!-- REVIEW_CARD rule_id="([^"]+)" -->([\s\S]*?)<!-- \/REVIEW_CARD -->/g;
        let match;
        let processed = text;
        while ((match = cardRegex.exec(text)) !== null) {
            const ruleId      = match[1];
            const criteria    = match[2].trim();
            const placeholder = 'REVIEW_CARD_PLACEHOLDER_' + pendingReviewCards.length;
            pendingReviewCards.push({ ruleId, criteria, placeholder });
            processed = processed.replace(match[0], '\n\n' + placeholder + '\n\n');
        }
        return processed;
    }

    function renderPendingReviewCards(bubble) {
        pendingReviewCards.forEach(card => {
            const walker = document.createTreeWalker(bubble, NodeFilter.SHOW_TEXT);
            let node;
            while (node = walker.nextNode()) {
                if (node.textContent.includes(card.placeholder)) {
                    const cardEl  = buildReviewCard(card.ruleId, card.criteria);
                    const wrapper = document.createElement('div');
                    wrapper.appendChild(cardEl);
                    node.parentNode.replaceChild(wrapper, node);
                    break;
                }
            }
        });
        pendingReviewCards = [];
    }

    function buildReviewCard(ruleId, criteria) {
        const card = document.createElement('div');
        card.className = 'review-card';
        card.id        = 'review-card-' + ruleId.replace(/[^a-z0-9]/gi, '-');
        const lines        = criteria.split('\n');
        const findingLines = lines.filter(l => l.trim().startsWith('- '));
        const introText    = lines.filter(l => !l.trim().startsWith('- ')).join(' ').trim();
        const state = { verdict: null, feedback: '', missing: '', corrections: [] };

        function render() {
            const safeId = ruleId.replace(/[^a-z0-9]/gi, '-');
            const findingsHtml = findingLines.length > 0
                ? '<div class="review-findings"><div class="panel-label" style="margin-bottom:6px;">Pages flagged:</div>' +
                  findingLines.map(l => '<div class="review-finding-row"><span class="review-finding-bullet">&#9888;</span><span>' + escapeHtml(l.replace(/^-\s*/, '')) + '</span></div>').join('') +
                  '</div>'
                : '<div class="review-criteria">' + escapeHtml(criteria) + '</div>';

            const correctionsHtml = (state.corrections.length > 0 || state.verdict === 'needs_revision')
                ? '<div style="margin-top:10px;"><div class="panel-label" style="margin-bottom:6px;">Misclassified pages</div>' +
                  '<div class="review-correction-list" id="corrections-' + safeId + '">' +
                  state.corrections.map((c, i) =>
                      '<div class="review-correction-row">' +
                      '<input class="review-correction-input" placeholder="/url/path/" value="' + escapeHtml(c.url || '') + '" onchange="reviewUpdateCorrection(\'' + ruleId + '\',' + i + ',\'url\',this.value)">' +
                      '<select class="review-correction-select" onchange="reviewUpdateCorrection(\'' + ruleId + '\',' + i + ',\'override\',this.value)">' +
                      '<option value="">→ should be</option>' +
                      '<option value="core"' + (c.override === 'core' ? ' selected' : '') + '>core</option>' +
                      '<option value="outer"' + (c.override === 'outer' ? ' selected' : '') + '>outer</option>' +
                      '</select>' +
                      '<input class="review-correction-input" placeholder="Reason (optional)" value="' + escapeHtml(c.reason || '') + '" onchange="reviewUpdateCorrection(\'' + ruleId + '\',' + i + ',\'reason\',this.value)">' +
                      '<button class="review-remove-btn" onclick="reviewRemoveCorrection(\'' + ruleId + '\',' + i + ')">&#x2715;</button>' +
                      '</div>'
                  ).join('') +
                  '</div><button class="review-add-correction" onclick="reviewAddCorrection(\'' + ruleId + '\')">+ Add correction</button></div>'
                : '';

            card.innerHTML =
                '<div class="review-card-header">' +
                '<div class="review-card-title">Rule Review &#8212; ' + escapeHtml(ruleId) + '</div>' +
                '<div class="review-card-sub">' + escapeHtml(introText || 'Are these findings correct?') + '</div>' +
                '</div>' +
                findingsHtml +
                '<hr class="review-divider">' +
                '<div class="review-row"><label>Findings correct?</label><div class="review-radio-group">' +
                '<button class="review-radio-btn agree' + (state.verdict === 'approved' ? ' selected' : '') + '" onclick="reviewSetVerdict(\'' + ruleId + '\',\'approved\')">&#10003; Agree</button>' +
                '<button class="review-radio-btn disagree' + (state.verdict === 'needs_revision' ? ' selected' : '') + '" onclick="reviewSetVerdict(\'' + ruleId + '\',\'needs_revision\')">&#x2717; Disagree</button>' +
                '</div></div>' +
                correctionsHtml +
                '<hr class="review-divider">' +
                '<div class="review-row" style="flex-direction:column;gap:5px;"><label>Missing from rule?</label>' +
                '<textarea class="review-missing" placeholder="Anything Logiri should consider that it didn\'t..." onchange="reviewSetMissing(\'' + ruleId + '\',this.value)">' + escapeHtml(state.missing) + '</textarea></div>' +
                '<hr class="review-divider">' +
                '<div class="review-row" style="flex-direction:column;gap:5px;"><label>Verdict</label><div class="review-verdict-group">' +
                '<button class="review-verdict-btn' + (state.verdict === 'approved' ? ' selected' : '') + '" onclick="reviewSetVerdict(\'' + ruleId + '\',\'approved\')">&#10003; Approve as-is</button>' +
                '<button class="review-verdict-btn' + (state.verdict === 'minor_changes' ? ' selected' : '') + '" onclick="reviewSetVerdict(\'' + ruleId + '\',\'minor_changes\')">Approve with minor changes</button>' +
                '<button class="review-verdict-btn' + (state.verdict === 'needs_revision' ? ' selected' : '') + '" onclick="reviewSetVerdict(\'' + ruleId + '\',\'needs_revision\')">Needs revision</button>' +
                '</div></div>' +
                '<button class="review-submit-btn" onclick="submitReview(\'' + ruleId + '\')">Submit Review</button>';
        }

        window._reviewCards = window._reviewCards || {};
        window._reviewCards[ruleId] = { state, render };
        render();
        return card;
    }

    window.reviewSetVerdict = function(ruleId, verdict) {
        const rc = window._reviewCards[ruleId];
        if (!rc) return;
        rc.state.verdict = verdict;
        if (verdict === 'needs_revision' && rc.state.corrections.length === 0)
            rc.state.corrections.push({ url: '', field: 'page_type', original: '', override: '', reason: '' });
        rc.render();
    };
    window.reviewSetMissing = function(ruleId, val) {
        const rc = window._reviewCards[ruleId]; if (rc) rc.state.missing = val;
    };
    window.reviewAddCorrection = function(ruleId) {
        const rc = window._reviewCards[ruleId]; if (!rc) return;
        rc.state.corrections.push({ url: '', field: 'page_type', original: '', override: '', reason: '' });
        rc.render();
    };
    window.reviewRemoveCorrection = function(ruleId, index) {
        const rc = window._reviewCards[ruleId]; if (!rc) return;
        rc.state.corrections.splice(index, 1); rc.render();
    };
    window.reviewUpdateCorrection = function(ruleId, index, field, value) {
        const rc = window._reviewCards[ruleId]; if (!rc) return;
        rc.state.corrections[index][field] = value;
    };

    window.submitReview = async function(ruleId) {
        const rc = window._reviewCards[ruleId];
        if (!rc || !rc.state.verdict) { showNotification('Please select a verdict before submitting.', 'red'); return; }
        const validCorrections = rc.state.corrections.filter(c => c.url && c.override);
        const res  = await fetch('/api/rule-review', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ rule_id: ruleId, verdict: rc.state.verdict, feedback: rc.state.missing || null, conversation_id: conversationId, corrections: validCorrections })
        });
        const data = await res.json();
        const cardEl = document.getElementById('review-card-' + ruleId.replace(/[^a-z0-9]/gi, '-'));
        if (cardEl) cardEl.innerHTML = '<div class="review-card-header"><div class="review-card-title">Rule Review &#8212; ' + escapeHtml(ruleId) + '</div></div><div class="review-submitted">&#10003; ' + (data.message || 'Review saved.') + '</div>';
        showNotification(data.message || 'Review saved.', 'green');
    };

    // Task Management
    async function startTask(id) {
        await fetch('/api/tasks/' + id + '/status', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ status: 'in_progress' }) });
        refreshTasksPanel();
    }
    function completeTask(id) {
        const taskEl       = document.getElementById('task-' + id);
        const title        = taskEl ? taskEl.querySelector('.task-title').textContent.trim() : 'Task #' + id;
        const cached       = window._taskCache && window._taskCache[id] ? window._taskCache[id] : {};
        const defaultDays  = cached.recheck_days || 14;
        const defaultCrit  = cached.recheck_criteria || '';
        document.getElementById('recheck-modal-title').textContent = title;
        document.getElementById('recheck-modal-days').value        = defaultDays;
        document.getElementById('recheck-modal-criteria').value    = defaultCrit;
        document.getElementById('recheck-modal-taskid').value      = id;
        document.getElementById('recheck-confirm-modal').classList.add('active');
    }

    async function confirmComplete() {
        const taskId   = parseInt(document.getElementById('recheck-modal-taskid').value);
        const days     = parseInt(document.getElementById('recheck-modal-days').value) || 14;
        const criteria = document.getElementById('recheck-modal-criteria').value.trim();
        document.getElementById('recheck-confirm-modal').classList.remove('active');

        const res  = await fetch('/api/tasks/' + taskId + '/complete', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ recheck_days: days, recheck_criteria: criteria })
        });
        const data = await res.json();

        // Animate task out of the list immediately
        const taskEl = document.getElementById('task-' + taskId);
        if (taskEl) {
            taskEl.style.transition = 'opacity 0.3s, transform 0.3s';
            taskEl.style.opacity    = '0';
            taskEl.style.transform  = 'translateX(20px)';
            setTimeout(() => taskEl.remove(), 320);
        }

        // Clear active task highlight if this was the active one
        if (currentTaskId === taskId) currentTaskId = null;

        // Switch to Rechecks tab and refresh so it appears immediately
        switchTab('rechecks');
        await refreshTasksPanel();

        showNotification('\u2713 Done \u2014 recheck set for ' + (data.recheck_date || days + 'd'), 'green');
    }
    async function verifyRecheck(id) {
        const passed = confirm('Did this task pass verification?\n\nOK = Pass\nCancel = Fail');
        await fetch('/api/tasks/' + id + '/verify', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ passed }) });
        sendMessage(passed ? 'Recheck #' + id + ' PASSED. Update the team.' : 'Recheck #' + id + ' FAILED. What should we do?');
        refreshTasksPanel();
    }

    async function editRecheckDate(id, currentDate) {
        const days = prompt('Recheck in how many days from today?\n(Current date: ' + currentDate + ')', '14');
        if (!days || isNaN(days) || parseInt(days) <= 0) return;
        const criteria = prompt('Pass criteria (what must be true on next crawl?)\nLeave blank to keep existing.', '');
        const body = { days: parseInt(days) };
        if (criteria !== null && criteria.trim()) body.criteria = criteria.trim();
        const res  = await fetch('/api/tasks/' + id + '/recheck-date', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(body)
        });
        const data = await res.json();
        const dateEl = document.getElementById('rdate-' + id);
        if (dateEl) dateEl.textContent = data.recheck_date;
        showNotification('Recheck updated: ' + data.recheck_date, 'green');
    }

    function appendTaskCards(tasksData) {
        if (!tasksData || tasksData.length === 0) return;

        // Build a map of title → task object (controller now returns full objects)
        const taskMap = {};
        tasksData.forEach(t => {
            if (t && t.title) taskMap[t.title.trim().toLowerCase()] = t;
        });

        // Find the last assistant bubble and inject task buttons inline after matching sections
        const bubbles = messagesEl.querySelectorAll('.message.assistant .bubble');
        const lastBubble = bubbles[bubbles.length - 1];
        if (!lastBubble) return;

        // Walk through headings (h2, h3, strong blocks) and inject a task card after relevant ones
        let injected = 0;
        const headings = lastBubble.querySelectorAll('h1, h2, h3, h4, strong');
        headings.forEach(heading => {
            const headingText = heading.textContent.trim().toLowerCase();
            // Find any task whose title shares keywords with this heading
            Object.entries(taskMap).forEach(([titleKey, task]) => {
                if (!task.id) return;
                const taskWords = titleKey.split(/\s+/).filter(w => w.length > 4);
                const matches   = taskWords.filter(w => headingText.includes(w));
                if (matches.length >= 2) {
                    // Check not already injected for this task
                    if (lastBubble.querySelector('[data-task-id="' + task.id + '"]')) return;
                    const card = buildInlineTaskCard(task);
                    // Insert after the parent paragraph/li of this heading
                    const parent = heading.closest('li, p') || heading;
                    parent.insertAdjacentElement('afterend', card);
                    injected++;
                }
            });
        });

        // For any tasks that weren't matched to a heading, append at the bottom
        const unmatched = tasksData.filter(t => {
            if (!t || !t.id) return false;
            return !lastBubble.querySelector('[data-task-id="' + t.id + '"]');
        });
        if (unmatched.length > 0) {
            const block = document.createElement('div');
            block.className = 'chat-task-inline-block';
            block.innerHTML = '<div style="font-size:11px;color:var(--text-muted);margin-bottom:6px;font-weight:600;padding-top:10px;border-top:1px solid var(--border-subtle);">Tasks added to your queue:</div>';
            unmatched.forEach(t => block.appendChild(buildInlineTaskCard(t)));
            lastBubble.appendChild(block);
        }

        messagesEl.scrollTop = messagesEl.scrollHeight;
    }

    function buildInlineTaskCard(task) {
        const card = document.createElement('div');
        card.className = 'chat-task-card priority-' + (task.priority || 'medium');
        card.setAttribute('data-task-id', task.id || '');
        const meta = '<div class="ctc-meta">' +
            '<span class="task-priority ' + (task.priority || 'medium') + '">' + (task.priority || 'medium') + '</span>' +
            (task.estimated_hours ? '<span>' + task.estimated_hours + 'h</span>' : '') +
            (task.assigned_to ? '<span>• ' + escapeHtml(task.assigned_to) + '</span>' : '') +
            '</div>';
        const title = '<div class="ctc-title">' + escapeHtml(task.title || '') + '</div>';
        const btnId = 'stbtn-' + (task.id || Math.random());
        const btn   = '<button id="' + btnId + '" class="chat-start-task-btn" onclick="startTaskFromChat(' + task.id + ', &quot;' + btnId + '&quot;)">&#9654; Run this Play</button>';
        card.innerHTML = meta + title + btn;
        return card;
    }

    function makeCollapsible(bubble) {
        // Find all h2/h3 headings and wrap their following content in collapsible sections
        const headings = Array.from(bubble.querySelectorAll('h2, h3'));
        headings.forEach(heading => {
            // Collect all sibling elements until the next heading
            const siblings = [];
            let next = heading.nextElementSibling;
            while (next && !['H2','H3'].includes(next.tagName)) {
                siblings.push(next);
                next = next.nextElementSibling;
            }
            if (siblings.length === 0) return;

            // Build collapsible wrapper
            const wrapper   = document.createElement('div');
            wrapper.className = 'collapsible-section collapsed';

            const toggle    = document.createElement('button');
            toggle.className = 'collapsible-toggle';

            // Extract first line as summary
            const firstSibling = siblings[0];
            const summary = firstSibling ? firstSibling.textContent.trim().slice(0, 90) : '';
            toggle.innerHTML =
                '<span class="collapsible-heading">' + heading.innerHTML + '</span>' +
                '<span class="collapsible-preview">' + escapeHtml(summary) + (summary.length >= 90 ? '\u2026' : '') + '</span>' +
                '<span class="collapsible-arrow">\u25BC</span>';

            const body = document.createElement('div');
            body.className = 'collapsible-body';
            siblings.forEach(s => body.appendChild(s));

            toggle.onclick = () => {
                const collapsed = wrapper.classList.toggle('collapsed');
                toggle.querySelector('.collapsible-arrow').textContent = collapsed ? '\u25BC' : '\u25B2';
            };

            wrapper.appendChild(toggle);
            wrapper.appendChild(body);
            heading.replaceWith(wrapper);
        });
    }

    function toggleTasksPanel() {
        const panel = document.getElementById('right-panel');
        const btn   = document.getElementById('tasks-toggle-btn');
        const isOpen = panel.classList.toggle('open');
        btn.classList.toggle('active', isOpen);
        if (isOpen) refreshTasksPanel();
    }

    async function startTaskFromChat(taskId, btnId) {
        if (btnId) {
            const btn = document.getElementById(btnId);
            if (btn) { btn.disabled = true; btn.classList.add('started'); btn.textContent = '\u2713 Starting\u2026'; }
        }

        await fetch('/api/tasks/' + taskId + '/status', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ status: 'in_progress' })
        });

        const taskRes  = await fetch('/api/tasks/' + taskId);
        const taskData = await taskRes.json();

        const panel = document.getElementById('right-panel');
        if (!panel.classList.contains('open')) toggleTasksPanel();
        await refreshTasksPanel();

        // Highlight task in sidebar
        currentTaskId = taskId;
        document.querySelectorAll('.task-item').forEach(el => el.classList.remove('selected'));
        const taskEl = document.getElementById('task-' + taskId);
        if (taskEl) { taskEl.classList.add('selected'); taskEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' }); }

        // Start fresh chat
        newChat();

        // Show a clean task header card in chat — no wall of text
        const taskTitle = taskData.title || 'Play #' + taskId;
        const priority  = taskData.priority || 'high';
        const hours     = taskData.estimated_hours || '?';
        const assigned  = taskData.assigned_to || '';

        const headerDiv = document.createElement('div');
        headerDiv.className = 'message assistant';
        headerDiv.innerHTML =
            '<div class="bubble play-header-bubble">' +
            '<div class="play-header-meta"><span class="task-priority ' + priority + '">' + priority + '</span>' +
            (hours ? '<span class="play-header-hours">' + hours + 'h</span>' : '') +
            (assigned ? '<span class="play-header-assigned">\u2192 ' + escapeHtml(assigned) + '</span>' : '') +
            '</div>' +
            '<div class="play-header-title">' + escapeHtml(taskTitle) + '</div>' +
            '<div class="play-header-hint">Ask me anything about this Play, or type <strong>brief me</strong> for a full step-by-step breakdown.</div>' +
            '</div>';
        messagesEl.appendChild(headerDiv);
        messagesEl.scrollTop = 0;

        showNotification('Play started \u2014 chat is ready', 'green');
    }

