<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Logiri — Double D Trailers</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/marked/9.1.6/marked.min.js"></script>
    <style>
        :root {
            --bg-primary:      #ffffff;
            --bg-secondary:    #f8f8fa;
            --bg-tertiary:     #f0f0f3;
            --bg-card:         #ffffff;
            --bg-card-hover:   #f4f4f8;
            --border-subtle:   #e4e4e8;
            --border-medium:   #d0d0d6;
            --border-accent:   #b0b0ba;
            --text-primary:    #1a1a1f;
            --text-secondary:  #5c5c66;
            --text-muted:      #9898a0;
            --accent-blue:     #2563eb;
            --accent-blue-dim: #eff4ff;
            --accent-blue-border: #bfdbfe;
            --accent-red:      #dc2626;
            --accent-red-dim:  #fef2f2;
            --accent-yellow:   #d97706;
            --accent-yellow-dim: #fffbeb;
            --accent-green:    #16a34a;
            --accent-green-dim: #f0fdf4;
            --accent-purple:   #7c3aed;
            --accent-purple-dim: #f5f3ff;
            --shadow-sm:  0 1px 2px rgba(0,0,0,0.04);
            --shadow-md:  0 1px 3px rgba(0,0,0,0.04), 0 4px 12px rgba(0,0,0,0.06);
            --shadow-lg:  0 8px 24px rgba(0,0,0,0.08);
            --radius-sm:  6px;
            --radius-md:  10px;
            --radius-lg:  14px;
            --font-display: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-body:    'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --font-mono:    'JetBrains Mono', monospace;
        }
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            font-family: var(--font-body);
            background: var(--bg-primary);
            color: var(--text-primary);
            height: 100vh;
            display: flex;
            overflow: hidden;
        }

        /* ── SCROLLBARS ─────────────────────────────── */
        ::-webkit-scrollbar { width: 4px; height: 4px; }
        ::-webkit-scrollbar-track { background: transparent; }
        ::-webkit-scrollbar-thumb { background: var(--border-medium); border-radius: 4px; }

        /* ── PERSONA OVERLAY ────────────────────────── */
        #persona-overlay {
            position: fixed; inset: 0; z-index: 1000;
            background: #f8f8fa;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            gap: 32px; padding: 40px;
            transition: opacity 0.3s;
        }
        #persona-overlay.hidden { display: none; }
        .persona-logo img { height: 32px; opacity: 0.9; }
        .persona-greeting { text-align: center; }
        .greeting-eyebrow {
            font-family: var(--font-mono);
            font-size: 11px; letter-spacing: 2px;
            color: var(--accent-blue); text-transform: uppercase;
            margin-bottom: 12px;
        }
        .persona-greeting h1 {
            font-family: var(--font-display);
            font-size: 32px; font-weight: 700;
            color: var(--text-primary); margin-bottom: 8px;
            letter-spacing: -0.5px;
        }
        .persona-greeting p { font-size: 15px; color: var(--text-secondary); }
        .persona-grid {
            display: flex; gap: 16px; flex-wrap: wrap;
            justify-content: center; max-width: 600px;
        }
        .persona-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            padding: 20px 24px;
            cursor: pointer;
            transition: all 0.2s;
            display: flex; align-items: center; gap: 14px;
            min-width: 200px;
        }
        .persona-card:hover {
            border-color: var(--accent-blue);
            background: var(--bg-card-hover);
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        .persona-avatar {
            width: 42px; height: 42px; border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 16px; font-weight: 700; color: white;
            flex-shrink: 0;
        }
        .persona-name { font-weight: 600; font-size: 15px; color: var(--text-primary); }
        .persona-role { font-size: 12px; color: var(--text-muted); margin-top: 2px; }

        /* ── LEFT SIDEBAR ───────────────────────────── */
        #sidebar {
            width: 220px; min-width: 220px;
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-subtle);
            display: flex; flex-direction: column;
            overflow: hidden;
        }
        #sidebar-header {
            padding: 14px 16px 12px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex; align-items: center; gap: 8px;
        }
        #sidebar-header img.logo-small {
            height: 20px; max-width: 80px; width: auto;
            flex-shrink: 0; object-fit: contain;
        }
        #sidebar-header h1 {
            font-family: var(--font-display);
            font-size: 16px; font-weight: 700;
            color: var(--text-primary); letter-spacing: -0.3px;
        }
        #sidebar-header p { font-size: 10px; color: var(--text-muted); margin-top: 1px; }
        .user-card {
            padding: 10px 14px;
            border-bottom: 1px solid var(--border-subtle);
            display: flex; align-items: center; gap: 8px;
        }
        .user-avatar {
            width: 28px; height: 28px; border-radius: 50%;
            background: var(--accent-blue-dim);
            border: 1px solid var(--accent-blue-border);
            display: flex; align-items: center; justify-content: center;
            font-size: 11px; font-weight: 700; color: var(--accent-blue);
            flex-shrink: 0;
        }
        .user-name { font-size: 13px; font-weight: 600; color: var(--text-primary); }
        .user-role { font-size: 11px; color: var(--text-muted); }
        .user-info { flex: 1; min-width: 0; }
        .user-logout {
            font-size: 11px; color: var(--text-muted);
            text-decoration: none;
            padding: 3px 6px; border-radius: 4px;
            transition: color 0.15s;
        }
        .user-logout:hover { color: var(--accent-red); }
        .sidebar-tabs {
            display: flex; border-bottom: 1px solid var(--border-subtle);
        }
        .sidebar-tab {
            flex: 1; padding: 8px 0; text-align: center;
            font-size: 12px; font-weight: 500; color: var(--text-muted);
            cursor: pointer; transition: all 0.15s;
            border-bottom: 2px solid transparent;
        }
        .sidebar-tab.active { color: var(--accent-blue); border-bottom-color: var(--accent-blue); }
        #sidebar-scroll { flex: 1; overflow-y: auto; }
        .new-chat-btn {
            display: block; width: calc(100% - 16px); margin: 10px 8px 6px;
            padding: 8px; background: var(--accent-blue);
            color: white; border: none; border-radius: var(--radius-sm);
            font-size: 12px; font-weight: 600; cursor: pointer;
            transition: opacity 0.15s; font-family: var(--font-body);
        }
        .new-chat-btn:hover { opacity: 0.85; }
        .history-group-label {
            font-size: 10px; font-weight: 600; letter-spacing: 1px;
            text-transform: uppercase; color: var(--text-muted);
            padding: 10px 14px 4px;
        }
        .convo-item {
            padding: 8px 14px; cursor: pointer;
            border-radius: var(--radius-sm); margin: 1px 6px;
            transition: background 0.15s; position: relative;
        }
        .convo-item:hover { background: var(--bg-card); }
        .convo-item.active { background: var(--accent-blue-dim); }
        .convo-title {
            font-size: 12px; color: var(--text-secondary);
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .convo-date { font-size: 10px; color: var(--text-muted); margin-top: 2px; }
        .convo-actions {
            position: absolute; right: 8px; top: 50%; transform: translateY(-50%);
            display: none; gap: 2px;
        }
        .convo-item:hover .convo-actions { display: flex; }
        .convo-action-btn {
            background: var(--bg-tertiary); border: none; cursor: pointer;
            padding: 3px 5px; border-radius: 3px; font-size: 10px;
            color: var(--text-muted);
        }
        .convo-action-btn:hover { color: var(--text-primary); }
        .convo-action-btn.delete:hover { color: var(--accent-red); }
        .history-empty {
            font-size: 12px; color: var(--text-muted);
            padding: 12px 14px; font-style: italic;
        }
        /* Rechecks panel */
        .sidebar-section-title {
            font-size: 10px; font-weight: 600; letter-spacing: 1px;
            text-transform: uppercase; color: var(--text-muted);
            padding: 10px 14px 6px;
        }
        .recheck-item {
            padding: 8px 14px; border-bottom: 1px solid var(--border-subtle);
        }
        .recheck-info { font-size: 12px; color: var(--text-secondary); }
        .recheck-date { font-size: 10px; color: var(--text-muted); margin-top: 2px; }
        .task-empty { font-size: 12px; color: var(--text-muted); padding: 10px 14px; font-style: italic; }

        /* ── MAIN CONTENT WRAPPER ───────────────────── */
        #app-wrapper {
            flex: 1; display: flex; flex-direction: column; overflow: hidden;
            position: relative;
        }

        /* ── TOP BAR ────────────────────────────────── */
        #top-bar {
            height: 52px; background: var(--bg-secondary);
            border-bottom: 1px solid var(--border-subtle);
            display: flex; align-items: center;
            padding: 0 20px; gap: 12px; flex-shrink: 0;
        }
        #board-back-btn {
            display: none; align-items: center; gap: 6px;
            background: var(--bg-tertiary); border: 1px solid var(--border-subtle);
            color: var(--text-secondary); padding: 5px 10px;
            border-radius: var(--radius-sm); cursor: pointer;
            font-size: 12px; font-weight: 500; font-family: var(--font-body);
            transition: all 0.15s;
        }
        #board-back-btn:hover { color: var(--text-primary); border-color: var(--border-medium); }
        #board-title {
            font-family: var(--font-display);
            font-size: 16px; font-weight: 700;
            color: var(--text-primary); letter-spacing: -0.3px;
            flex: 1;
        }
        .topbar-stats {
            display: flex; gap: 8px; align-items: center;
        }
        .topbar-stat {
            display: flex; align-items: center; gap: 5px;
            font-size: 12px; color: var(--text-muted);
            padding: 4px 10px;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-sm);
        }
        .topbar-stat-num {
            font-family: var(--font-mono); font-size: 13px;
            font-weight: 600;
        }
        .topbar-stat-num.pending  { color: var(--accent-yellow); }
        .topbar-stat-num.active   { color: var(--accent-blue); }
        .topbar-stat-num.done     { color: var(--accent-green); }
        .topbar-filter-group {
            display: flex; gap: 4px;
        }
        .topbar-filter-btn {
            padding: 4px 10px; border-radius: var(--radius-sm);
            font-size: 11px; font-weight: 500;
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            color: var(--text-muted); cursor: pointer;
            font-family: var(--font-body); transition: all 0.15s;
        }
        .topbar-filter-btn.active {
            background: var(--accent-blue-dim);
            border-color: var(--accent-blue-border);
            color: var(--accent-blue);
        }
        .topbar-filter-btn:hover:not(.active) { color: var(--text-primary); }

        /* ── BOARD VIEW ─────────────────────────────── */
        #board-view {
            flex: 1; display: flex; flex-direction: column;
            overflow: hidden; padding: 20px;
            gap: 16px;
        }
        .board-signal-bar {
            background: linear-gradient(135deg, #f5f3ff 0%, #eff4ff 100%);
            border: 1px solid var(--border-subtle);
            border-left: 3px solid var(--accent-purple);
            border-radius: var(--radius-md);
            padding: 10px 16px;
            display: flex; align-items: center; gap: 12px;
            font-size: 12px; color: var(--text-secondary);
        }
        .board-signal-bar .signal-icon {
            font-size: 14px; color: var(--accent-purple);
        }
        .board-signal-bar strong { color: var(--text-primary); }
        #board-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 14px;
            flex: 1;
            overflow: hidden;
        }
        /* ── BOARD COLUMNS ── */
        .board-column {
            display: flex; flex-direction: column;
            flex: 1; min-width: 220px; max-width: 320px;
            background: #f8f8fa;
            border: 1px solid #e8e8ec;
            border-radius: 10px;
            overflow: hidden;
        }
        .board-col-header {
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 12px 14px 10px;
            border-bottom: 1px solid #e8e8ec;
        }
        .board-col-label {
            font-size: 12px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.5px;
        }
        .board-col-count {
            font-size: 11px; font-weight: 700;
            padding: 2px 8px; border-radius: 20px;
        }
        .board-lane {
            display: flex; flex-direction: column;
            gap: 8px; padding: 10px; overflow-y: auto;
            flex: 1;
        }
        .board-empty-lane {
            text-align: center; font-size: 12px;
            color: #9898a0; padding: 20px 0; font-style: italic;
        }

        /* ── BOARD CARDS ── */
        .board-card {
            background: #fff;
            border: 1px solid #e4e4e8;
            border-left: 3px solid #d0d0d6;
            border-radius: 8px;
            padding: 10px 12px;
            cursor: pointer;
            transition: box-shadow 0.15s, transform 0.1s;
            animation: cardIn 0.25s ease both;
            display: flex; flex-direction: column; gap: 5px;
        }
        .board-card:hover {
            box-shadow: 0 2px 8px rgba(0,0,0,0.1);
            transform: translateY(-1px);
        }
        .board-card.priority-critical { border-left-color: #ef4444; }
        .board-card.priority-high     { border-left-color: #f59e0b; }
        .board-card.priority-medium   { border-left-color: #3b82f6; }
        .board-card.priority-low      { border-left-color: #9ca3af; }
        .board-card-top {
            display: flex; justify-content: space-between;
            align-items: center;
        }
        .board-card-hours {
            font-size: 11px; font-weight: 600;
            color: #5c5c66; background: #f0f0f3;
            padding: 1px 6px; border-radius: 4px;
        }
        .board-card-assignee {
            font-size: 11px; color: #9898a0;
        }
        .board-card-title {
            font-size: 13px; font-weight: 600;
            color: #1a1a1f; line-height: 1.4;
        }
        .board-card-url {
            font-size: 11px; color: #2563eb;
            font-family: 'JetBrains Mono', monospace;
            white-space: nowrap; overflow: hidden;
            text-overflow: ellipsis;
        }
        .board-card-run {
            margin-top: 2px;
            display: flex; align-items: center;
            justify-content: center; gap: 4px;
            padding: 5px 8px;
            background: transparent;
            border: 1px solid #e4e4e8;
            border-radius: 5px;
            color: #5c5c66;
            font-size: 11px; font-weight: 600;
            cursor: pointer; font-family: inherit;
            transition: all 0.15s;
            width: 100%;
        }
        .board-card:hover .board-card-run {
            background: #2563eb;
            border-color: #2563eb;
            color: #fff;
        }
        .board-card-done-badge {
            font-size: 11px; color: #16a34a;
            font-weight: 600; text-align: center;
            padding: 3px 0;
        }
        @keyframes cardIn {
            from { opacity: 0; transform: translateY(6px); }
            to   { opacity: 1; transform: translateY(0); }
        }

        /* ── SIGNAL BAR ── */
        .board-signal-bar {
            background: linear-gradient(135deg, #f5f3ff 0%, #eff4ff 100%);
            border: 1px solid #e0e7ff;
            border-radius: 8px;
            padding: 10px 16px;
            display: flex; align-items: center; gap: 10px;
            font-size: 12px; color: #5c5c66;
            margin-bottom: 0;
        }
        .signal-icon { font-size: 16px; }

        /* ── RIGHT PANEL (task detail + add task) ── */
        #task-detail-panel {
            position: fixed; top: 0; right: 0; bottom: 0;
            width: 320px; background: #fff;
            border-left: 1px solid #e4e4e8;
            z-index: 100; transform: translateX(100%);
            transition: transform 0.25s ease;
            display: flex; flex-direction: column;
            box-shadow: -4px 0 20px rgba(0,0,0,0.06);
        }
        #task-detail-panel.open { transform: translateX(0); }
        #panel-header {
            display: flex; align-items: center;
            justify-content: space-between;
            padding: 16px 18px;
            border-bottom: 1px solid #e4e4e8;
        }
        #panel-title { font-size: 14px; font-weight: 700; color: #1a1a1f; }
        #panel-close {
            background: none; border: none; cursor: pointer;
            font-size: 16px; color: #9898a0; padding: 2px 6px;
        }
        #panel-close:hover { color: #1a1a1f; }
        #panel-body { padding: 16px 18px; flex: 1; overflow-y: auto; }
        #panel-actions {
            display: flex; gap: 8px; padding: 14px 18px;
            border-top: 1px solid #e4e4e8;
        }
        .panel-btn {
            flex: 1; padding: 8px;
            border-radius: 6px; border: 1px solid #e4e4e8;
            font-size: 12px; font-weight: 600;
            cursor: pointer; font-family: inherit;
        }
        .panel-btn.start { background: #eff4ff; color: #2563eb; border-color: #bfdbfe; }
        .panel-btn.done  { background: #f0fdf4; color: #16a34a; border-color: #bbf7d0; }
        .panel-btn:hover { opacity: 0.85; }

        /* ── ADD TASK MODAL ── */
        #add-task-modal {
            display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.25);
            align-items: center; justify-content: center;
        }
        #add-task-modal.active { display: flex; }
        .modal-box {
            background: #fff; border: 1px solid #e4e4e8;
            border-radius: 12px; padding: 24px; width: 400px;
            box-shadow: 0 8px 32px rgba(0,0,0,0.12);
        }
        .modal-title {
            font-size: 16px; font-weight: 700;
            color: #1a1a1f; margin-bottom: 18px;
        }
        .modal-field { margin-bottom: 14px; }
        .modal-label {
            font-size: 12px; font-weight: 600;
            color: #5c5c66; margin-bottom: 5px;
        }
        .modal-input, .modal-select, .modal-textarea {
            width: 100%; padding: 8px 10px;
            border: 1px solid #e4e4e8; border-radius: 6px;
            font-size: 13px; font-family: inherit;
            color: #1a1a1f; background: #fff;
            box-sizing: border-box;
        }
        .modal-input:focus, .modal-textarea:focus {
            outline: none; border-color: #2563eb;
            box-shadow: 0 0 0 2px #eff4ff;
        }
        .modal-textarea { resize: vertical; min-height: 72px; }
        .modal-actions {
            display: flex; gap: 8px; justify-content: flex-end;
            margin-top: 18px;
        }
        .modal-btn {
            padding: 8px 18px; border-radius: 6px;
            font-size: 13px; font-weight: 600;
            cursor: pointer; font-family: inherit; border: none;
        }
        .modal-btn.cancel { background: #f0f0f3; color: #5c5c66; }
        .modal-btn.save   { background: #2563eb; color: #fff; }
        .modal-btn:hover  { opacity: 0.88; }

        #chat-view {
            flex: 1; display: none; flex-direction: column;
            overflow: hidden; max-width: 820px;
            margin: 0 auto; width: 100%; padding: 0 20px;
        }
        #messages {
            flex: 1; overflow-y: auto; padding: 20px 0 10px;
            display: flex; flex-direction: column; gap: 16px;
        }
        .message { display: flex; }
        .message.user { justify-content: flex-end; }
        .message.assistant { justify-content: flex-start; }
        .bubble {
            max-width: 75%;
            padding: 12px 16px;
            border-radius: var(--radius-lg);
            font-size: 14px; line-height: 1.65;
        }
        .message.user .bubble {
            background: var(--accent-blue);
            color: white; border-radius: var(--radius-lg) var(--radius-lg) 4px var(--radius-lg);
        }
        .message.assistant .bubble {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            color: var(--text-primary);
            border-radius: var(--radius-lg) var(--radius-lg) var(--radius-lg) 4px;
        }
        .bubble h2, .bubble h3 { font-size: 14px; margin: 12px 0 6px; color: var(--text-primary); font-family: var(--font-display); }
        .bubble h2:first-child, .bubble h3:first-child { margin-top: 0; }
        .bubble p { margin-bottom: 8px; }
        .bubble p:last-child { margin-bottom: 0; }
        .bubble ul, .bubble ol { padding-left: 18px; margin-bottom: 8px; }
        .bubble li { margin-bottom: 4px; }
        .bubble strong { color: var(--text-primary); font-weight: 600; }
        .bubble code {
            font-family: var(--font-mono); font-size: 12px;
            background: var(--bg-tertiary); padding: 1px 5px;
            border-radius: 3px; color: var(--accent-blue);
        }
        .bubble pre {
            background: var(--bg-tertiary); padding: 10px 12px;
            border-radius: var(--radius-sm); overflow-x: auto;
            margin: 8px 0; border: 1px solid var(--border-subtle);
        }
        .bubble pre code { background: none; padding: 0; color: var(--text-secondary); }

        /* Thinking indicator */
        .typing-indicator {
            padding: 8px 0; display: none;
        }
        .thinking-bubble {
            display: inline-flex; align-items: center; gap: 10px;
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg) var(--radius-lg) var(--radius-lg) 4px;
            padding: 10px 14px;
        }
        .thinking-bar {
            width: 80px; height: 3px;
            background: var(--border-medium); border-radius: 2px; overflow: hidden;
        }
        .thinking-bar-fill {
            height: 100%; width: 40%; background: var(--accent-blue);
            border-radius: 2px;
            animation: thinkSlide 1.4s ease-in-out infinite;
        }
        @keyframes thinkSlide {
            0%   { transform: translateX(-100%); }
            100% { transform: translateX(300%); }
        }
        .thinking-text { font-size: 13px; color: var(--text-muted); font-style: italic; }

        /* Chat input */
        #input-area {
            padding: 12px 0 20px;
            display: flex; gap: 8px; align-items: flex-end;
        }
        #input {
            flex: 1; background: var(--bg-card);
            border: 1px solid var(--border-medium);
            border-radius: var(--radius-md);
            padding: 10px 14px;
            color: var(--text-primary);
            font-family: var(--font-body); font-size: 14px;
            resize: none; outline: none; line-height: 1.5;
            transition: border-color 0.15s;
            min-height: 46px; max-height: 120px;
        }
        #input:focus { border-color: var(--accent-blue); }
        #input::placeholder { color: var(--text-muted); }
        #send {
            padding: 10px 18px;
            background: var(--accent-blue);
            color: white; border: none;
            border-radius: var(--radius-md);
            font-size: 13px; font-weight: 600;
            cursor: pointer; font-family: var(--font-body);
            transition: opacity 0.15s; white-space: nowrap;
        }
        #send:hover { background: #1d4ed8; }
        #mark-done-btn {
            padding: 10px 16px;
            background: var(--accent-green); color: #fff;
            border: none; border-radius: var(--radius-md);
            font-size: 13px; font-weight: 600;
            cursor: pointer; white-space: nowrap;
            display: none; align-items: center;
        }
        #mark-done-btn:hover { background: #15803d; }
        #send:hover { opacity: 0.85; }
        #send:disabled { opacity: 0.4; cursor: not-allowed; }

        /* ── COLLAPSIBLE SECTIONS ────────────────────── */
        .collapsible-toggle { cursor: pointer; user-select: none; }
        .collapsible-body { overflow: hidden; }
        .collapsible-body.collapsed { display: none; }

        /* ── REVIEW CARDS ───────────────────────────── */
        .review-card {
            background: var(--bg-card);
            border: 1px solid var(--border-medium);
            border-radius: var(--radius-lg);
            padding: 16px; margin: 8px 0;
        }
        .review-card-header {
            font-family: var(--font-display);
            font-size: 13px; font-weight: 700;
            color: var(--accent-yellow); margin-bottom: 10px;
        }
        .review-label {
            font-size: 10px; font-weight: 700; letter-spacing: 1px;
            text-transform: uppercase; color: var(--text-muted); margin-bottom: 6px;
        }
        .review-findings { margin-bottom: 12px; }
        .review-finding-item {
            display: flex; align-items: flex-start; gap: 6px;
            padding: 5px 0; border-bottom: 1px solid var(--border-subtle);
            font-size: 12px; color: var(--text-secondary);
        }
        .review-finding-item:last-child { border-bottom: none; }
        .review-finding-warn { color: var(--accent-yellow); font-size: 12px; }
        .review-verdict { display: flex; gap: 6px; margin: 10px 0 8px; flex-wrap: wrap; }
        .review-agree-btn, .review-disagree-btn {
            padding: 6px 14px; border-radius: var(--radius-sm);
            font-size: 12px; font-weight: 600; cursor: pointer;
            font-family: var(--font-body); border: 1px solid;
            transition: all 0.15s;
        }
        .review-agree-btn {
            background: var(--accent-green-dim); border-color: #34d39944;
            color: var(--accent-green);
        }
        .review-agree-btn:hover { background: var(--accent-green); color: white; }
        .review-disagree-btn {
            background: var(--accent-red-dim); border-color: #f0525244;
            color: var(--accent-red);
        }
        .review-disagree-btn:hover { background: var(--accent-red); color: white; }
        .review-feedback { width: 100%; margin: 6px 0; }
        .review-feedback textarea {
            width: 100%; background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-sm);
            color: var(--text-primary); font-family: var(--font-body);
            font-size: 12px; padding: 8px 10px; resize: vertical;
            min-height: 60px; outline: none;
        }
        .review-feedback textarea:focus { border-color: var(--accent-blue); }
        .review-verdict-btns { display: flex; gap: 6px; flex-wrap: wrap; margin: 6px 0; }
        .review-verdict-btn {
            padding: 5px 12px; border-radius: var(--radius-sm);
            font-size: 11px; font-weight: 600; cursor: pointer;
            font-family: var(--font-body);
            background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            color: var(--text-secondary); transition: all 0.15s;
        }
        .review-verdict-btn:hover { border-color: var(--accent-blue); color: var(--accent-blue); }
        .review-submit-btn {
            padding: 8px 18px;
            background: var(--accent-blue); border: none;
            border-radius: var(--radius-sm); color: white;
            font-size: 12px; font-weight: 600; cursor: pointer;
            font-family: var(--font-body); transition: opacity 0.15s;
        }
        .review-submit-btn:hover { opacity: 0.85; }

        /* ── PLAY BUTTONS IN CHAT ───────────────────── */
        .chat-plays-strip {
            margin-top: 14px; padding-top: 12px;
            border-top: 1px solid var(--border-subtle);
        }
        .chat-plays-label {
            font-size: 10px; font-weight: 700; letter-spacing: 0.8px;
            text-transform: uppercase; color: var(--text-muted); margin-bottom: 7px;
        }
        .chat-play-btn {
            display: flex; align-items: center; justify-content: space-between;
            width: 100%; margin-bottom: 5px; padding: 8px 12px;
            background: var(--bg-tertiary); border: 1px solid var(--border-subtle);
            border-left: 3px solid var(--accent-yellow);
            border-radius: var(--radius-sm); cursor: pointer;
            transition: all 0.15s; text-align: left;
            font-family: var(--font-body);
        }
        .chat-play-btn:hover { border-color: var(--accent-blue); border-left-color: var(--accent-blue); background: var(--accent-blue-dim); }
        .chat-play-btn.priority-critical { border-left-color: #ef4444; }
        .chat-play-btn.priority-high     { border-left-color: #f59e0b; }
        .chat-play-btn.priority-medium   { border-left-color: #4f8ef7; }
        .cpb-title { font-size: 12px; font-weight: 500; color: var(--text-primary); flex: 1; margin-right: 10px; }
        .cpb-meta  { font-size: 10px; color: var(--text-muted); white-space: nowrap; }
        .cpb-arrow { font-size: 11px; color: var(--accent-blue); margin-left: 8px; flex-shrink: 0; }

        /* ── NOTIFICATION TOAST ─────────────────────── */
        #notification {
            position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%);
            background: var(--bg-card); border: 1px solid var(--border-medium);
            border-radius: var(--radius-md);
            padding: 10px 18px; font-size: 13px;
            color: var(--text-primary); z-index: 500;
            box-shadow: var(--shadow-lg);
            transition: opacity 0.3s;
        }
        #notification.hidden { opacity: 0; pointer-events: none; }

        /* ── ADD TASK MODAL ─────────────────────────── */
        #add-task-modal {
            display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.25); align-items: center; justify-content: center;
        }
        #add-task-modal.open { display: flex; }
        .modal-box {
            background: var(--bg-card); border: 1px solid var(--border-medium);
            border-radius: var(--radius-lg); padding: 24px; width: 440px; max-width: 95vw;
        }
        .modal-title {
            font-family: var(--font-display);
            font-size: 16px; font-weight: 700;
            color: var(--text-primary); margin-bottom: 16px;
        }
        .modal-field { margin-bottom: 12px; }
        .modal-label { font-size: 11px; font-weight: 600; color: var(--text-muted); margin-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px; }
        .modal-input, .modal-select {
            width: 100%; background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-sm); padding: 8px 10px;
            color: var(--text-primary); font-family: var(--font-body);
            font-size: 13px; outline: none; transition: border-color 0.15s;
        }
        .modal-input:focus, .modal-select:focus { border-color: var(--accent-blue); }
        .modal-select option { background: var(--bg-card); }
        .modal-actions { display: flex; gap: 8px; margin-top: 16px; justify-content: flex-end; }
        .modal-cancel {
            padding: 8px 16px; background: var(--bg-tertiary);
            border: 1px solid var(--border-subtle); border-radius: var(--radius-sm);
            color: var(--text-muted); cursor: pointer;
            font-family: var(--font-body); font-size: 13px;
        }
        .modal-submit {
            padding: 8px 16px; background: var(--accent-blue);
            border: none; border-radius: var(--radius-sm);
            color: white; cursor: pointer;
            font-family: var(--font-body); font-size: 13px; font-weight: 600;
        }

        /* ── TASK DETAIL PANEL (slide-over) ─────────── */
        #task-detail-panel {
            position: fixed; top: 0; right: 0; bottom: 0;
            width: 380px; background: var(--bg-card);
            border-left: 1px solid var(--border-medium);
            z-index: 100; transform: translateX(100%);
            transition: transform 0.25s ease;
            display: flex; flex-direction: column;
            overflow: hidden; box-shadow: var(--shadow-lg);
        }
        #task-detail-panel.open { transform: translateX(0); }
        #panel-header {
            padding: 16px 18px; border-bottom: 1px solid var(--border-subtle);
            display: flex; align-items: center; gap: 10px;
        }
        #panel-title {
            flex: 1; font-family: var(--font-display);
            font-size: 14px; font-weight: 700; color: var(--text-primary);
        }
        #panel-close {
            background: none; border: none; cursor: pointer;
            color: var(--text-muted); font-size: 16px; padding: 2px 6px;
        }
        #panel-close:hover { color: var(--text-primary); }
        #panel-body { flex: 1; overflow-y: auto; padding: 16px 18px; }
        .task-priority {
            display: inline-block; font-size: 10px; font-weight: 700;
            text-transform: uppercase; letter-spacing: 0.5px;
            padding: 2px 8px; border-radius: 10px;
        }
        .task-priority.critical { background: #fef2f2; color: var(--accent-red); }
        .task-priority.high     { background: var(--accent-yellow-dim); color: var(--accent-yellow); }
        .task-priority.medium   { background: var(--accent-blue-dim); color: var(--accent-blue); }
        .task-priority.low      { background: var(--bg-tertiary); color: var(--text-muted); }
        #panel-actions { padding: 14px 18px; border-top: 1px solid var(--border-subtle); display: flex; gap: 8px; }
        .panel-btn {
            flex: 1; padding: 9px; border-radius: var(--radius-sm);
            font-size: 12px; font-weight: 600; cursor: pointer;
            font-family: var(--font-body); border: 1px solid;
            transition: all 0.15s;
        }
        .panel-btn.start {
            background: var(--accent-blue); border-color: var(--accent-blue); color: white;
        }
        .panel-btn.done {
            background: var(--accent-green-dim); border-color: #34d39944; color: var(--accent-green);
        }
        .panel-btn.done:hover { background: var(--accent-green); color: white; }
        .recheck-modal { display: none; }
        input#recheck-modal-taskid { display: none; }
        /* ── ACTIVITY FEED ── */
        .activity-item {
            display: flex; gap: 8px; padding: 8px 14px;
            border-bottom: 1px solid var(--border-subtle);
            font-size: 12px;
        }
        .activity-icon {
            flex-shrink: 0; width: 20px; text-align: center;
            font-size: 12px; color: var(--accent-blue); margin-top: 1px;
        }
        .activity-body { flex: 1; min-width: 0; }
        .activity-actor { font-weight: 600; color: var(--text-primary); }
        .activity-action { color: var(--text-secondary); }
        .activity-target {
            color: var(--text-primary); font-weight: 500;
            display: block; white-space: nowrap; overflow: hidden;
            text-overflow: ellipsis; margin-top: 2px;
        }
        .activity-details {
            font-size: 11px; color: var(--text-muted);
            margin-top: 2px; font-style: italic;
        }
        .activity-time { font-size: 10px; color: var(--text-muted); margin-top: 3px; }

        /* ── ADD RULE MODAL ── */
        #add-rule-modal {
            display: none; position: fixed; inset: 0; z-index: 200;
            background: rgba(0,0,0,0.25); align-items: center; justify-content: center;
        }
        #add-rule-modal.open { display: flex; }

        /* ── DASHBOARD VIEW ───────────────────────────── */
        #dashboard-view {
            flex: 1; overflow-y: auto; padding: 32px 24px;
            display: none;
        }
        #dashboard-view.active { display: block; }
        .dash-container { max-width: 1100px; margin: 0 auto; }
        .dash-grid {
            display: grid; grid-template-columns: repeat(4, 1fr);
            gap: 16px; margin-bottom: 32px;
        }
        @media (max-width: 900px) {
            .dash-grid { grid-template-columns: repeat(2, 1fr); }
        }
        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-md);
            padding: 20px;
            transition: box-shadow 0.2s;
        }
        .stat-card:hover { box-shadow: var(--shadow-md); }
        .stat-label {
            font-size: 12px; color: var(--text-muted);
            text-transform: uppercase; letter-spacing: 0.5px;
            margin-bottom: 4px;
        }
        .stat-value { font-size: 28px; font-weight: 700; }
        .stat-sub { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
        .stat-card.blue .stat-value   { color: var(--accent-blue); }
        .stat-card.green .stat-value  { color: var(--accent-green); }
        .stat-card.red .stat-value    { color: var(--accent-red); }
        .stat-card.yellow .stat-value { color: var(--accent-yellow); }

        .dash-section-title {
            font-size: 16px; font-weight: 600;
            margin-bottom: 16px; display: flex;
            align-items: center; gap: 8px;
        }
        .dash-badge {
            font-size: 11px; background: var(--bg-tertiary);
            color: var(--text-muted); padding: 2px 8px;
            border-radius: 20px; font-weight: 500;
        }

        /* Focus cards */
        .focus-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-lg);
            padding: 24px; margin-bottom: 16px;
            display: flex; align-items: center;
            gap: 20px; cursor: pointer;
            transition: box-shadow 0.2s, transform 0.15s;
        }
        .focus-card:hover {
            box-shadow: var(--shadow-md);
            transform: translateY(-1px);
        }
        .focus-num {
            font-size: 32px; font-weight: 700;
            color: var(--text-muted); min-width: 40px;
            text-align: center; flex-shrink: 0;
        }
        .focus-content { flex: 1; min-width: 0; }
        .focus-title {
            font-size: 14px; font-weight: 600;
            margin-bottom: 4px; color: var(--text-primary);
        }
        .focus-url {
            font-size: 12px; color: var(--accent-blue);
            font-family: var(--font-mono); margin-bottom: 6px;
            white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
        }
        .focus-meta { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
        .focus-tag {
            font-size: 11px; padding: 2px 8px;
            border-radius: 4px; font-weight: 500;
        }
        .focus-tag.critical { background: #fef2f2; color: #dc2626; }
        .focus-tag.high     { background: #fff7ed; color: #c2410c; }
        .focus-tag.medium   { background: #fefce8; color: #a16207; }
        .focus-tag.low      { background: var(--bg-tertiary); color: var(--text-muted); }
        .focus-tag.hours    { background: var(--bg-tertiary); color: var(--text-muted); }
        .focus-rule-id {
            font-size: 11px; color: var(--text-muted);
        }
        .focus-action {
            padding: 10px 20px; background: var(--accent-blue);
            color: white; border: none; border-radius: 8px;
            font-size: 13px; font-weight: 600; cursor: pointer;
            white-space: nowrap; font-family: var(--font-body);
            transition: background 0.15s; flex-shrink: 0;
        }
        .focus-action:hover { background: #1d4ed8; }
        .dash-view-all {
            text-align: center; margin: 16px 0 32px;
        }
        .dash-view-all button {
            padding: 8px 20px; border: 1px solid var(--border-subtle);
            border-radius: 8px; background: transparent;
            font-size: 13px; cursor: pointer;
            color: var(--text-secondary); font-family: var(--font-body);
            transition: all 0.15s;
        }
        .dash-view-all button:hover {
            border-color: var(--accent-blue);
            color: var(--accent-blue);
        }

        /* Results grid */
        .results-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 16px; margin-bottom: 32px;
        }
        @media (max-width: 700px) {
            .results-grid { grid-template-columns: 1fr; }
        }
        .result-card {
            background: var(--bg-card);
            border: 1px solid var(--border-subtle);
            border-radius: var(--radius-md);
            padding: 16px; display: flex;
            gap: 12px; align-items: flex-start;
            transition: box-shadow 0.2s;
        }
        .result-card:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
        .result-icon {
            font-size: 18px; min-width: 28px; height: 28px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 6px; flex-shrink: 0;
        }
        .result-icon.pass { background: #f0fdf4; color: var(--accent-green); }
        .result-icon.fail { background: #fef2f2; color: var(--accent-red); }
        .result-icon.partial { background: #fefce8; color: var(--accent-yellow); }
        .result-content { flex: 1; min-width: 0; }
        .result-title { font-size: 13px; font-weight: 600; margin-bottom: 2px; }
        .result-detail {
            font-size: 12px; color: var(--text-secondary); line-height: 1.5;
        }
        .result-metric {
            font-size: 11px; color: var(--text-muted); margin-top: 4px;
            font-family: var(--font-mono);
        }

        /* Rule proposal cards */
        .proposal-card {
            background: var(--bg-card);
            border: 1px solid #fde68a;
            border-radius: var(--radius-md);
            padding: 16px; margin-bottom: 12px;
        }
        .proposal-header {
            display: flex; align-items: center;
            justify-content: space-between;
            margin-bottom: 8px;
        }
        .proposal-rule { font-size: 13px; font-weight: 600; }
        .proposal-type {
            font-size: 11px; color: var(--accent-yellow);
            background: #fefce8; padding: 2px 8px; border-radius: 4px;
        }
        .proposal-text {
            font-size: 13px; color: var(--text-secondary);
            line-height: 1.5; margin-bottom: 12px;
        }
        .proposal-actions { display: flex; gap: 8px; }
        .proposal-actions button {
            padding: 6px 14px; border-radius: 6px;
            font-size: 12px; font-weight: 500;
            cursor: pointer; border: 1px solid var(--border-subtle);
            background: var(--bg-card); font-family: var(--font-body);
            transition: all 0.15s;
        }
        .proposal-actions button.approve {
            background: var(--accent-green); color: white;
            border-color: var(--accent-green);
        }
        .proposal-actions button.approve:hover { background: #15803d; }
        .proposal-actions button.reject { color: var(--text-muted); }
        .proposal-actions button.reject:hover {
            color: var(--accent-red);
            border-color: var(--accent-red);
        }
        .proposal-actions button:hover:not(.approve):not(.reject) {
            border-color: var(--accent-blue);
            color: var(--accent-blue);
        }
        .dash-empty {
            text-align: center; padding: 24px;
            color: var(--text-muted); font-size: 13px;
            font-style: italic;
        }

        /* Header nav pills */
        .header-nav-pills {
            display: flex; gap: 4px;
            background: var(--bg-tertiary);
            border-radius: 8px; padding: 3px;
        }
        .header-nav-pill {
            padding: 6px 14px; border: none;
            background: transparent; border-radius: 6px;
            font-size: 12px; font-weight: 500;
            cursor: pointer; color: var(--text-muted);
            font-family: var(--font-body);
            transition: all 0.15s;
        }
        .header-nav-pill.active {
            background: var(--bg-card);
            color: var(--text-primary);
            box-shadow: var(--shadow-sm);
            font-weight: 600;
        }
        .header-nav-pill:hover:not(.active) { color: var(--text-primary); }
    </style>
</head>
<body>

<!-- ── Persona Picker Overlay ── -->
<div id="persona-overlay" class="{{ showPersonaPicker ? '' : 'hidden' }}">
    <div class="persona-logo">
        <img src="/logiri-logo-small.png" alt="Logiri">
    </div>
    <div class="persona-greeting">
        <div class="greeting-eyebrow">Logiri · Signal Engine</div>
        <h1>Who's running the Playbook today?</h1>
        <p>Select your profile to tailor Signals, Plays, and briefings.</p>
    </div>
    <div class="persona-grid">
        {% for member in teamMembers %}
        <div class="persona-card" onclick="selectPersona('{{ member.name }}', '{{ member.role }}')">
            <div class="persona-avatar" style="background: {{ member.color }};">{{ member.avatar }}</div>
            <div class="persona-info">
                <div class="persona-name">{{ member.name }}</div>
                <div class="persona-role">{{ member.role }}</div>
            </div>
        </div>
        {% endfor %}
    </div>
</div>



<!-- ── SIDEBAR ─────────────────────────────────── -->
<div id="sidebar">
    <div id="sidebar-header">
        <img src="/logiri-logo-small.png" alt="Logiri" class="logo-small">
        <div>
            <h1>Logiri</h1>
            <p>Signal Engine</p>
        </div>
    </div>
    <div class="user-card">
        <div class="user-avatar">{{ userName[:2]|upper }}</div>
        <div class="user-info">
            <div class="user-name">{{ userName }}</div>
            <div class="user-role">{{ userRole }}</div>
        </div>
        <button class="user-logout" onclick="showPersonaPicker()" title="Switch" style="background:none;border:none;cursor:pointer;padding:0;margin-right:4px;">⇄</button>
        <a href="{{ logout_path() }}" class="user-logout">Out</a>
    </div>
    <div class="sidebar-tabs">
        <div class="sidebar-tab active" id="tab-history" onclick="switchTab('history')">History</div>
        <div class="sidebar-tab" id="tab-rechecks" onclick="switchTab('rechecks')">Rechecks</div>
        <div class="sidebar-tab" id="tab-activity" onclick="switchTab('activity')">Activity</div>
    </div>
    <div id="sidebar-scroll">
        <div id="panel-history">
            <button class="new-chat-btn" onclick="switchView('dashboard')">⬛ Dashboard</button>
            <div id="history-list">
                {% if conversations is empty %}
                    <div class="history-empty">No conversations yet.</div>
                {% else %}
                    <div class="history-group-label">Recent</div>
                    {% for convo in conversations|slice(0, 10) %}
                        <div class="convo-item" id="convo-{{ convo.id }}" onclick="loadConversationFromSidebar({{ convo.id }})">
                            <div class="convo-title">{{ convo.title ?? 'Conversation #' ~ convo.id }}</div>
                            <div class="convo-date">{{ convo.updated_at|date('M j') }}</div>
                            <div class="convo-actions">
                                <button class="convo-action-btn" onclick="event.stopPropagation(); startRename({{ convo.id }})">✎</button>
                                <button class="convo-action-btn delete" onclick="event.stopPropagation(); deleteConvo({{ convo.id }})">✕</button>
                            </div>
                        </div>
                    {% endfor %}
                {% endif %}
            </div>
        </div>
        <div id="panel-rechecks" style="display:none;">
            <div class="sidebar-section" style="border-bottom:none;">
                <div class="sidebar-section-title">Pending Rechecks</div>
                <div id="recheck-list">
                    {% if rechecks is empty %}
                        <div class="task-empty">No rechecks pending</div>
                    {% else %}
                        {% for r in rechecks %}
                        <div class="recheck-item">
                            <div class="recheck-info">{{ r.title }}</div>
                            <div class="recheck-date">Due {{ r.recheck_date|date('M j') }}</div>
                        </div>
                        {% endfor %}
                    {% endif %}
                </div>
            </div>
        </div>
        <div id="panel-activity" style="display:none;">
            <div class="sidebar-section" style="border-bottom:none;">
                <div class="sidebar-section-title">Team Activity</div>
                <div id="activity-list">
                    <div class="task-empty">Loading activity...</div>
                </div>
            </div>
        </div>
    </div>
</div>

